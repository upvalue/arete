// vim: set ft=cpp

// vm-native-x64.cpp.dasc - Hand-written AMD64 dispatch core for the Arete VM.
//
// LuaJIT-interpreter-style replacement for the switch/computed-goto loop in
// src/vm.cpp. NOT the method-JIT in src/compile-x64.cpp.dasc — that file
// compiles each function's bytecode to its own native blob; this file
// assembles ONE shared dispatch blob at startup that every native-VM-enabled
// VMFunction reuses. Bytecode is unchanged.
//
// Rollout is step-by-step (see docs/Native VM.md). S2 handles only
// OP_ARGC_EQ, OP_PUSH_IMMEDIATE, OP_RETURN — enough for ((lambda () #t)).
//
// Pinned registers (callee-saved, held across the whole dispatch loop):
//   r12 = STATE  (arete::State*)
//   r13 = CP     (size_t*, current bytecode pointer)
//   r14 = STACK  (Value*, computation-stack top)
//   r15 = LOCALS (Value*, base of local-variable slots; unused in S2)
//   rbx = VFN    (arete::VMFunction*)
// Non-pinned scratch we actively use:
//   r10 = ARGC   (set at entry, consumed by arity checks)
//   r11 = DTABLE (pointer to opcode→handler array)

#include "arete.hpp"

#if AR_64_BIT == 1 && !defined(_MSC_VER) && !defined(__EMSCRIPTEN__) && \
    (defined(__x86_64__) || defined(_M_X64))

#include <algorithm>
#include <cstring>

#define DASM_CHECKS
#define DASM_FDEF static

#include "dasm_proto.h"
#include "dasm_x86.h"

namespace arete {

void native_vm_mark_ready();
extern Value fn_apply(State& state, size_t argc, Value* argv, void* v);
extern size_t native_vm_stat_apply_vm_path;
extern size_t native_vm_stat_apply_c_path;
extern size_t native_vm_stat_apply_tail_vm_path;
extern size_t native_vm_stat_apply_tail_c_path;
extern size_t native_vm_stat_apply_c_cfunction;
extern size_t native_vm_stat_apply_c_no_native_bit;
extern size_t native_vm_stat_apply_c_arity_range;
extern size_t native_vm_stat_apply_c_argc_mismatch;
extern size_t native_vm_stat_apply_c_variadic;
extern size_t native_vm_stat_apply_c_boxed;

// Signature of the assembled dispatch entry. vfn_ref is a *pointer* to a
// GC-updated Value slot (the fn variable in apply_native_vm, registered with
// AR_FRAME). The dispatch core reloads the VMFunction pointer through that
// slot after any C helper that might have allocated, since the moving GC
// may have relocated the VMFunction in the meantime.
//
// The current frame base and the current Closure are both derived from the
// top VMCallFrame record in state->gc.vm_frames: the caller pushes the
// session-base record before invoking the dispatch core, and the asm call /
// return paths push and pop records exactly like apply_vm does. On exception
// the core returns with this session's records still on vm_frames so
// apply_native_vm can run the same unwind loop apply_vm uses.
typedef Value (*native_vm_dispatch_fn)(
    State* state, Value* vfn_ref, Value* locals, Value* stack,
    size_t argc, size_t* cp);

static native_vm_dispatch_fn native_vm_dispatch = nullptr;

// Direct-indexed by opcode. Dispatch tail does `jmp [r11 + rax*8]`. Slots
// this core doesn't yet handle point at the bad-opcode trampoline so an
// eligibility bug manifests as a readable exception, not wild control flow.
static void* dispatch_table[OP_VALUE_HEADER_BIT + 1];

#define NATIVE_VM_PAIR_CAR_OFF ((ptrdiff_t) offsetof(Pair, data_car))
#define NATIVE_VM_PAIR_CDR_OFF ((ptrdiff_t) offsetof(Pair, data_cdr))

// --- VMCallFrame record access from assembly --------------------------------
// The asm core pushes/pops the same VMCallFrame records apply_vm uses, by
// manipulating gc.vm_frames' libstdc++ internals directly: a std::vector is
// {T* begin, T* finish, T* end_of_storage}. finish is the push/pop cursor;
// finish == end_of_storage means a push must go through the C grow helper.
// init_native_vm verifies this layout at startup and aborts on mismatch
// (fallback then: hand-rolled POD frame stack on State).
#define NATIVE_VM_FRAMES_OFF ((ptrdiff_t)(offsetof(State, gc) + offsetof(GCCommon, vm_frames)))
#define NATIVE_VM_FRAMES_FINISH_OFF (NATIVE_VM_FRAMES_OFF + 8)
#define NATIVE_VM_FRAMES_EOS_OFF (NATIVE_VM_FRAMES_OFF + 16)
#define NATIVE_VM_STACK_OFF ((ptrdiff_t)(offsetof(State, gc) + offsetof(GCCommon, vm_stack)))
#define NATIVE_VM_STACK_USED_OFF ((ptrdiff_t)(offsetof(State, gc) + offsetof(GCCommon, vm_stack_used)))
#define NATIVE_VM_STACK_SIZE_OFF ((ptrdiff_t)(offsetof(State, gc) + offsetof(GCCommon, vm_stack_size)))

static_assert(sizeof(VMCallFrame) == 40, "asm frame push/pop assumes 40-byte VMCallFrame");
static_assert(offsetof(VMCallFrame, closure) == 0, "asm assumes closure at +0");
static_assert(offsetof(VMCallFrame, frame_base) == 8, "asm assumes frame_base at +8");
static_assert(offsetof(VMCallFrame, return_cp) == 16, "asm assumes return_cp at +16");
static_assert(offsetof(VMCallFrame, result_slot) == 24, "asm assumes result_slot at +24");
static_assert(offsetof(VMCallFrame, frames_lost) == 32, "asm assumes frames_lost at +32");
static_assert(offsetof(VMCallFrame, flags) == 36, "asm assumes flags at +36");
#define FR_SIZE ((ptrdiff_t) sizeof(VMCallFrame))

#define NATIVE_VM_DISPATCH_OPS(_) \
  _(OP_ARGC_EQ, op_argc_eq) \
  _(OP_PUSH_IMMEDIATE, op_push_immediate) \
  _(OP_RETURN, op_return) \
  _(OP_ARGC_GTE, op_argc_gte) \
  _(OP_LOCAL_GET, op_local_get) \
  _(OP_LOCAL_SET, op_local_set) \
  _(OP_POP, op_pop) \
  _(OP_PUSH_CONSTANT, op_push_constant) \
  _(OP_JUMP, op_jump) \
  _(OP_JUMP_WHEN, op_jump_when) \
  _(OP_JUMP_WHEN_POP, op_jump_when_pop) \
  _(OP_JUMP_UNLESS, op_jump_unless) \
  _(OP_GLOBAL_GET, op_global_get) \
  _(OP_GLOBAL_SET, op_global_set) \
  _(OP_FX_ADD, op_fx_add) \
  _(OP_FX_SUB, op_fx_sub) \
  _(OP_FX_LT, op_fx_lt) \
  _(OP_EQ, op_eq) \
  _(OP_NOT, op_not) \
  _(OP_FIXNUMP, op_fixnump) \
  _(OP_CAR, op_car) \
  _(OP_CDR, op_cdr) \
  _(OP_TYPE_CHECK, op_type_check) \
  _(OP_ADD, op_add) \
  _(OP_SUB, op_sub) \
  _(OP_LT, op_lt) \
  _(OP_APPLY, op_apply) \
  _(OP_APPLY_TAIL, op_apply_tail) \
  _(OP_BOX_FROM_LOCAL, op_box_from_local) \
  _(OP_BOX_FROM_CLOSURE, op_box_from_closure) \
  _(OP_BOX_GET, op_box_get) \
  _(OP_BOX_SET, op_box_set) \
  _(OP_CLOSE_OVER, op_close_over) \
  _(OP_ARGV_REST, op_argv_rest) \
  _(OP_JUMP_IF_NOT_NIL, op_jump_if_not_nil) \
  _(OP_JUMP_IF_NIL, op_jump_if_nil) \
  _(OP_JUMP_IF_NOT_PAIR, op_jump_if_not_pair) \
  _(OP_JUMP_IF_PAIR, op_jump_if_pair) \
  _(OP_JUMP_IF_EQ_IMM, op_jump_if_eq_imm) \
  _(OP_JUMP_IF_NOT_EQ_IMM, op_jump_if_not_eq_imm) \
  _(OP_CADR, op_cadr) \
  _(OP_CDDR, op_cddr) \
  _(OP_CAAR, op_caar) \
  _(OP_CDAR, op_cdar) \
  _(OP_CADDR, op_caddr) \
  _(OP_APPLY_GLOBAL, op_apply_global) \
  _(OP_APPLY_TAIL_GLOBAL, op_apply_tail_global) \
  _(OP_APPLY_LOCAL, op_apply_local) \
  _(OP_APPLY_TAIL_LOCAL, op_apply_tail_local) \
  _(OP_CAPTURE_FROM_LOCAL, op_capture_from_local) \
  /* FROM_CLOSURE and GET share a label: both read current_closure->captures[idx] raw. */ \
  _(OP_CAPTURE_FROM_CLOSURE, op_capture_ref) \
  _(OP_CAPTURE_GET, op_capture_ref) \
  _(OP_VALUE_TYPE, op_value_type) \
  _(OP_VALUE_HEADER_BIT, op_value_header_bit)

// Called from assembly when OP_ARGC_EQ fails.
static Value native_vm_argc_error(State* state, size_t got, size_t expected) {
  std::ostringstream os;
  os << "function expected exactly " << expected << " arguments but got "
     << got;
  return state->make_exception(State::S_EVAL_ERROR, os.str());
}

static Value native_vm_argc_gte_error(State* state, size_t got, size_t expected) {
  std::ostringstream os;
  os << "function expected at least " << expected << " arguments but got "
     << got;
  return state->make_exception(State::S_EVAL_ERROR, os.str());
}

static Value native_vm_bad_opcode(State* state) {
  return state->make_exception(State::S_EVAL_ERROR,
      "native VM dispatched an unimplemented opcode; coverage bug");
}

// Raised from the asm call fast path when vm_depth + 1 would reach the
// recursion limit. Mirrors apply_vm's message exactly. (The baseline asm
// core skipped this check entirely and segfaulted on runaway non-tail
// recursion once vm_stack realloc failed.)
static Value native_vm_recursion_limit_error(State* state) {
  std::ostringstream os;
  os << " non-tail recursive calls exceeded RECURSION-LIMIT ("
     << state->recursion_limit << ')';
  return state->make_exception(State::S_EVAL_ERROR, os.str());
}



static Value native_vm_global_undefined(State* state, Value sym, size_t was_set) {
  std::ostringstream os;
  if(was_set) {
    os << "attempt to set! undefined variable " << sym;
  } else {
    os << "reference to undefined variable " << sym;
  }
  return state->make_exception(State::S_EVAL_ERROR, os.str());
}

// Error helper for OP_VALUE_HEADER_BIT when v is an immediate. Mirrors the
// fn_value_header_bit error path verbatim.
static Value native_vm_value_header_bit_immediate_error(State* state) {
  return state->make_exception(State::S_EVAL_ERROR,
      "value-header bit got immediate object");
}

// Error helper for OP_VALUE_HEADER_BIT when bit-idx isn't a fixnum.
static Value native_vm_value_header_bit_nonfixnum_error(State* state) {
  return state->make_exception(
      "type", "vm primitive value-header-bit? expected a fixnum bit index");
}

// Type-error helper for CAR/CDR (pair check).
static Value native_vm_pair_error(State* state, Value got, size_t is_cdr) {
  std::ostringstream os;
  os << "vm primitive " << (is_cdr ? "cdr" : "car")
     << " expected a pair as its argument but got " << got.type();
  return state->make_exception("type", os.str());
}

// Helpers for variadic + / - / <. These mirror the apply_vm cases and include
// the fixnum fast path / flonum fallback. Return an active exception on type
// error, a numeric Value otherwise.
static Value native_vm_op_add(State* state, size_t argc, Value* args) {
  ptrdiff_t fx = 0;
  size_t i = 0;
  for(; i < argc; i++) {
    Value n = args[i];
    if(n.fixnump()) {
      fx += n.fixnum_value();
    } else break;
  }
  if(i == argc) return Value::make_fixnum(fx);
  double fl = (double) fx;
  for(; i < argc; i++) {
    Value n = args[i];
    if(n.fixnump()) fl += (double) n.fixnum_value();
    else if(n.heap_type_equals(FLONUM)) fl += n.flonum_value();
    else {
      std::ostringstream os;
      os << "vm primitive + expected a fixnum or flonum but got " << n.type();
      return state->make_exception("type", os.str());
    }
  }
  return state->make_flonum(fl);
}

static Value native_vm_op_sub(State* state, size_t argc, Value* args) {
  if(argc == 0) {
    return state->make_exception(State::S_EVAL_ERROR,
        "vm primitive - expects at least one argument");
  }
  if(argc == 1) {
    Value n = args[0];
    if(n.fixnump()) return Value::make_fixnum(-n.fixnum_value());
    if(n.heap_type_equals(FLONUM)) return state->make_flonum(-n.flonum_value());
    std::ostringstream os;
    os << "vm primitive - expected fixnum or flonum but got " << n.type();
    return state->make_exception("type", os.str());
  }
  Value head = args[0];
  ptrdiff_t fx = 0;
  size_t i = 1;
  for(; i < argc; i++) {
    Value n = args[i];
    if(n.fixnump()) fx += n.fixnum_value();
    else break;
  }
  if(i == argc) {
    if(head.fixnump()) return Value::make_fixnum(head.fixnum_value() - fx);
    // head is numeric but not fixnum — treat as flonum subtraction with a
    // fixnum tail.
    if(head.heap_type_equals(FLONUM)) return state->make_flonum(head.flonum_value() - fx);
    std::ostringstream os;
    os << "vm primitive - expected fixnum or flonum but got " << head.type();
    return state->make_exception("type", os.str());
  }
  double fl = (double) fx;
  for(; i < argc; i++) {
    Value n = args[i];
    if(n.fixnump()) fl += (double) n.fixnum_value();
    else if(n.heap_type_equals(FLONUM)) fl += n.flonum_value();
    else {
      std::ostringstream os;
      os << "vm primitive - expected fixnum or flonum but got " << n.type();
      return state->make_exception("type", os.str());
    }
  }
  if(head.fixnump()) return state->make_flonum((double)head.fixnum_value() - fl);
  if(head.heap_type_equals(FLONUM)) return state->make_flonum(head.flonum_value() - fl);
  std::ostringstream os;
  os << "vm primitive - expected fixnum or flonum but got " << head.type();
  return state->make_exception("type", os.str());
}

static Value native_vm_op_lt(State* state, size_t argc, Value* args) {
  // Transliteration of apply_vm OP_LT. Iterates pairwise; any adjacent pair
  // not strictly increasing short-circuits to #f.
  for(size_t i = 0; i + 1 < argc; i++) {
    Value a = args[i], b = args[i + 1];
    if(!a.numeric()) {
      std::ostringstream os;
      os << "< expects all numeric arguments but argument " << i+1
         << " is a " << a.type();
      return state->make_exception("type", os.str());
    }
    if(!b.numeric()) {
      std::ostringstream os;
      os << "< expects all numeric arguments but argument " << i+2
         << " is a " << b.type();
      return state->make_exception("type", os.str());
    }
    bool ok;
    if(a.fixnump()) {
      if(b.fixnump()) ok = a.fixnum_value() < b.fixnum_value();
      else            ok = (double) a.fixnum_value() < b.flonum_value();
    } else {
      if(b.fixnump()) ok = a.flonum_value() < (double) b.fixnum_value();
      else            ok = a.flonum_value() < b.flonum_value();
    }
    if(!ok) return C_FALSE;
  }
  return C_TRUE;
}

// OP_TYPE_CHECK — ape apply_vm exactly: push Value(bool) where bool is the
// raw equality result. That produces 0 or 1, which round-trips through Value
// the same way apply_vm does.
static Value native_vm_op_type_check(Value v, size_t tipe) {
  return Value((ptrdiff_t)(v.type() == (Type) tipe));
}

static void native_vm_grow_stack(State* state, size_t size) {
  state->gc.grow_stack(size);
}

// Cold path for the asm call fast paths: raise the vm_stack high-water mark
// to `extent` (growing the backing store if needed and zeroing exactly the
// newly included region, mirroring apply_vm's enter:), and ensure vm_frames
// has room for one more record. The asm side takes the inline path only when
// extent is at or under the high-water mark AND a record slot is free.
static void native_vm_prepare_frame(State* state, size_t extent) {
  size_t old_used = state->gc.vm_stack_used;
  if(extent > old_used) {
    size_t delta = extent - old_used;
    state->gc.grow_stack(delta);
    // Slots above the old high-water mark are realloc garbage, or stale
    // values a GC ran past while a nested session had shrunk the mark.
    memset((void*) &state->gc.vm_stack[old_used], 0, delta * sizeof(Value));
  }
  std::vector<VMCallFrame>& v = state->gc.vm_frames;
  if(v.size() == v.capacity()) {
    v.reserve(v.capacity() ? v.capacity() * 2 : 1024);
  }
}

static void native_vm_close_frame_boxes(
    State* state, VMFunction* vfn, size_t sff_offset) {
  if(vfn->box_count == 0) return;

  Value* boxes = &state->gc.vm_stack[sff_offset + vfn->local_count];
  for(size_t i = 0; i != vfn->box_count; i++) {
    if(!boxes[i].heap_type_equals(BOX) || boxes[i].box_closed()) {
      continue;
    }

    size_t idx = boxes[i].as_unsafe<Box>()->U.vm_local_idx;
    if(idx >= state->gc.vm_stack_used) {
      continue;
    }

    boxes[i].as_unsafe<Box>()->U.converted = state->gc.vm_stack[idx];
    boxes[i].heap->set_header_bit(Value::BOX_CLOSED_BIT);
  }
}

// Cold path for the asm call fast paths: allocate the open Boxes for the
// frame just entered (the top vm_frames record). The frame is fully
// committed before this runs: args sit in the frame's locals on vm_stack
// (rooted by the stack scan) and the record roots the closure, so each
// allocation may GC — re-derive the VMFunction from the record afterwards.
// Mirrors apply_vm's enter: box loop (src/vm.cpp:282).
static void native_vm_alloc_frame_boxes(State* state) {
  Value closure = state->gc.vm_frames.back().closure;
  VMFunction* vfn = closure.closure_unbox().as_unsafe<VMFunction>();
  size_t sff_offset = state->gc.vm_frames.back().frame_base;
  size_t fv_length = vfn->free_variables->length;
  Value* boxes = &state->gc.vm_stack[sff_offset + vfn->local_count];
  for(size_t i = 0; i != fv_length; i++) {
    boxes[i] = state->gc.allocate(BOX, sizeof(Box));
    closure = state->gc.vm_frames.back().closure;
    vfn = closure.closure_unbox().as_unsafe<VMFunction>();
    size_t local_idx = ((size_t*) vfn->free_variables->data)[i];
    boxes[i].as<Box>()->U.vm_local_idx = sff_offset + local_idx;
  }
}

// Cold path for the asm call fast paths: finish entering a just-committed
// variadic frame (the top vm_frames record). The fast path skipped its
// inline zero loop — that loop's count (local_count + box_count - argc)
// goes negative when extras are supplied — so this does all slot init
// beyond the args: build the rest list from the extras at
// locals[max_arity..argc), store it at locals[max_arity], zero the
// remaining locals + box slots, then allocate any open Boxes. Mirrors
// apply_native_vm's variable-arity prologue (and apply_vm's OP_ARGV_REST,
// src/vm.cpp:1068). temps_to_list can GC, so everything read from the
// VMFunction is cached up front; the extras stay GC-scannable in vm_stack
// throughout (they sit below the high-water mark) and temps are roots.
static void native_vm_enter_variadic(State* state, size_t argc) {
  Value closure = state->gc.vm_frames.back().closure;
  VMFunction* vfn = closure.closure_unbox().as_unsafe<VMFunction>();
  size_t frame_base = state->gc.vm_frames.back().frame_base;
  size_t max_arity = vfn->max_arity;
  size_t fi = (size_t) vfn->local_count + vfn->box_count;
  size_t box_count = vfn->box_count;

  Value rest = C_NIL;
  if(argc > max_arity) {
    Value* args = &state->gc.vm_stack[frame_base];
    state->temps.clear();
    state->temps.insert(state->temps.end(), &args[max_arity], &args[argc]);
    rest = state->temps_to_list();
  }
  state->gc.vm_stack[frame_base + max_arity] = rest;

  // Everything the skipped inline zero loop would have initialized,
  // including slots where extras sat. Slots beyond fi need nothing: the
  // eval region is write-before-read and already scannable.
  if(fi > max_arity + 1) {
    memset((void*) &state->gc.vm_stack[frame_base + max_arity + 1], 0,
           (fi - max_arity - 1) * sizeof(Value));
  }

  if(box_count) {
    native_vm_alloc_frame_boxes(state);
  }
}

static Value native_vm_flatten_apply_arguments(
    State* state, size_t argc, Value* argv, Value* out_fn) {
  Value fn = argv[0];
  if(!fn.procedurep()) {
    return state->type_error("apply: argument 1 is not a procedure");
  }

  Value lst = argv[argc - 1];
  Value original_lst = lst;
  AR_FRAME(*state, fn, lst, original_lst);

  size_t lst_length = (argc - 2) + original_lst.list_length();
  if(original_lst != C_NIL && lst_length == 0) {
    return state->type_error("apply: argument 2 is not a proper list");
  }

  state->temps.clear();
  if(argc > 2) {
    state->temps.insert(state->temps.end(), &argv[1], &argv[argc - 1]);
  }

  while(lst.heap_type_equals(PAIR)) {
    state->temps.push_back(lst.car());
    lst = lst.cdr();
  }

  AR_ASSERT(state->temps.size() == lst_length);
  *out_fn = fn;
  return C_FALSE;
}

static Value native_vm_apply_error(State* state, Value fn) {
  std::ostringstream os;
  os << "vm: attempt to apply non-applicable value " << fn;
  return state->make_exception(State::S_EVAL_ERROR, os.str());
}

// Set by the asm exception epilogue: the current frame's bytecode offset (in
// words) at the moment the exception left the dispatch core. apply_native_vm
// uses it as the innermost frame's trace offset, mirroring apply_vm's
// `trace_off = cp - code`. Single-threaded, like the tail stash below.
static size_t native_vm_exc_cp_offset = 0;

// Tail-call communication. The OP_APPLY_TAIL helper sets these; the outer
// apply_native_vm loop reads them after the dispatch returns and, if
// native_vm_tail_flag is true, jumps back to its `tail:` label with the new
// args — matching apply_vm's goto-tail TCO.
static bool native_vm_tail_flag = false;
static size_t native_vm_tail_argc = 0;
static void* native_vm_tail_fnp = nullptr;
// Dedicated fixed-size buffer for the asm-inlined tail stash. Sized so that
// the common case (Scheme tail calls with ≤64 args) fits without a grow
// check. Larger tail calls fall through to the C helper's state.temps path.
// Tail stash is single-threaded (one dispatch at a time) so this is safe.
static const size_t NATIVE_VM_TAIL_BUF_CAP = 64;
static Value native_vm_tail_buf[NATIVE_VM_TAIL_BUF_CAP];
// 0 = args live in state.temps (slow path / large argc); 1 = args live in
// native_vm_tail_buf (asm fast path).
static size_t native_vm_tail_use_buf = 0;

// Returns {is_tail, value}. If the target is a VMFunction/Closure we stash
// args in state->temps, raise the tail flag, and return {1, 0} (the value
// is ignored on the tail path). Otherwise we call the target inline and
// return {0, result}; the dispatch core then returns that result directly,
// matching apply_vm's handling of OP_APPLY_TAIL for non-VM targets.
struct TailResult {
  ptrdiff_t is_tail;
  Value     result;
};
// S9 helpers — closures + captures.

// Read a closure's idx'th capture slot, dereferencing through the Box
// object if the slot is boxed. Matches apply_vm's OP_BOX_GET semantics.
static Value native_vm_box_get(State* state, Value closure, size_t idx) {
  Value slot = closure.as_unsafe<Closure>()->captures->data[idx];
  if(!slot.heap_type_equals(BOX)) return slot;
  Box* box = slot.as_unsafe<Box>();
  if(box->get_header_bit(Value::BOX_CLOSED_BIT)) return box->U.converted;
  if(box->get_header_bit(Value::BOX_POINTER_BIT)) return *box->U.local;
  return state->gc.vm_stack[box->U.vm_local_idx];
}

static void native_vm_box_set(State* state, Value closure, size_t idx, Value val) {
  Value slot = closure.as_unsafe<Closure>()->captures->data[idx];
  if(!slot.heap_type_equals(BOX)) {
    closure.as_unsafe<Closure>()->captures->data[idx] = val;
    return;
  }
  Box* box = slot.as_unsafe<Box>();
  if(box->get_header_bit(Value::BOX_CLOSED_BIT)) {
    box->U.converted = val;
  } else {
    state->gc.vm_stack[box->U.vm_local_idx] = val;
  }
}

// Allocate a VectorStorage + Closure, copy `count` capture slots from the
// stack top, wire up function + procedure_addr. Returns the new Closure
// Value. The caller pops `count + 1` slots and writes the result to stack[-1].
static Value native_vm_close_over(State* state, Value* stack_top, size_t count) {
  // stack_top points one past the topmost stack value. Captures live at
  // stack_top-count .. stack_top-1; fn is at stack_top-(count+1).
  Value storage, closure, fn;
  AR_FRAME(*state, storage, closure, fn);

  fn = stack_top[-(ptrdiff_t)(count + 1)];

  storage = state->make_vector_storage(count);
  for(size_t i = 0; i < count; i++) {
    // apply_vm iterates from the bottommost capture upward via STACK_PICK(count-i).
    // With storage appending in order, this matches: storage[i] = stack_top[-(count - i)].
    state->vector_storage_append(storage, stack_top[-(ptrdiff_t)(count - i)]);
  }

  closure = state->gc.allocate(CLOSURE, sizeof(Closure));
  closure.as_unsafe<Closure>()->captures = storage.as<VectorStorage>();
  closure.as_unsafe<Closure>()->function = fn;
  closure.procedure_install(fn.as_unsafe<Procedure>()->procedure_addr);
  return closure;
}

// When allow_tail is nonzero, a native-VM VMFunction/Closure target is
// handled by raising the tail flag so apply_native_vm restarts with the new
// fn. When zero (the caller is inside a nested fast-path frame), the tail
// flag path is unsafe — setting it would unwind apply_native_vm's top-level
// frame instead of just the current frame — so we treat the call like a
// non-tail apply: invoke procedure_addr directly and let the dispatch core
// write the result and fall through to op_return.
static TailResult native_vm_op_apply_tail(
    State* state, Value fn, Value* args, size_t argc, size_t allow_tail) {
  TailResult r;
  Value afn = fn;
  AR_FRAME(*state, afn);

  if(afn.heap_type_equals(CFUNCTION) &&
     afn.as_unsafe<Procedure>()->procedure_addr == &fn_apply) {
    Value flat_error = native_vm_flatten_apply_arguments(state, argc, args, &afn);
    if(flat_error != C_FALSE) {
      r.is_tail = 0;
      r.result = flat_error;
      return r;
    }

    argc = state->temps.size();
    args = state->temps.empty() ? nullptr : state->temps.data();
  }

  Value unboxed = afn.closure_unbox();
  if(allow_tail &&
     unboxed.heap_type_equals(VMFUNCTION) &&
     unboxed.heap->get_header_bit(Value::VMFUNCTION_NATIVE_VM_BIT)) {
    state->temps.clear();
    state->temps.insert(state->temps.end(), args, args + argc);
    native_vm_tail_use_buf = 0;
    native_vm_tail_flag = true;
    native_vm_tail_argc = argc;
    native_vm_tail_fnp  = (void*) afn.bits;
    r.is_tail = 1;
    r.result  = C_FALSE;
    return r;
  }

  Value result = afn.as_unsafe<Procedure>()->procedure_addr(
      *state, argc, args, afn.heap);
  r.is_tail = 0;
  r.result  = result;
  return r;
}

// Verify at startup that std::vector<VMCallFrame> has the {begin, finish,
// end_of_storage} pointer layout the assembled push/pop code assumes. If a
// toolchain ever breaks this, fail loudly at init rather than corrupting
// memory at the first Scheme call. (Escape hatch then: replace gc.vm_frames
// with a hand-rolled POD frame stack.)
static void native_vm_verify_frames_layout(State& state) {
  std::vector<VMCallFrame>& v = state.gc.vm_frames;
  static_assert(sizeof(std::vector<VMCallFrame>) == 3 * sizeof(void*),
                "vm_frames asm access expects a 3-pointer std::vector");
  VMCallFrame probe;
  probe.closure = C_FALSE;
  probe.frame_base = 0;
  probe.return_cp = 0;
  probe.result_slot = 0;
  probe.frames_lost = 0;
  probe.flags = 0;
  v.push_back(probe);
  void** raw = (void**) &v;
  bool ok = raw[0] == (void*) v.data() &&
            (char*) raw[1] == (char*) v.data() + v.size() * sizeof(VMCallFrame) &&
            (char*) raw[2] == (char*) v.data() + v.capacity() * sizeof(VMCallFrame);
  v.pop_back();
  if(!ok) {
    fprintf(stderr,
            "arete: std::vector<VMCallFrame> layout does not match native VM "
            "assumptions; rebuild with NATIVE_VM_ENABLE=0 or port "
            "vm-native-x64.cpp.dasc to this C++ runtime\n");
    abort();
  }
}

void init_native_vm(State& state) {
  native_vm_verify_frames_layout(state);

  |.arch x64
  |.section code

  dasm_State* d;
  dasm_init(&d, DASM_MAXSECTION);

  |.actionlist actions
  |.globals G_
  |.globalnames globalnames

  void* globals[G__MAX == 0 ? 1 : G__MAX];
  (void) globalnames;

  dasm_setupglobal(&d, globals, G__MAX);
  dasm_setup(&d, actions);

  dasm_State** Dst = &d;

  |.define STATE,  r12
  |.define CP,     r13
  |.define STACK,  r14
  |.define LOCALS, r15
  |.define VFN,    rbx
  |.define ARGC,   r10
  |.define DTABLE, r11

  |.define sVfnRef,     [rsp]
  |.define sSffOffset,  [rsp+8]
  |.define sClosureRef, [rsp+16]
  |.define sCodeBase,   [rsp+24]
  |.define sScratch0,   [rsp+32]
  |.define sScratch1,   [rsp+40]
  |.define sScratch2,   [rsp+48]

  |.macro returnEpilogue
  | add rsp, 72
  | pop r15
  | pop r14
  | pop r13
  | pop r12
  | pop rbp
  | pop rbx
  | ret
  |.endmacro

  |.macro reloadDtable
  | mov64 DTABLE, (ptrdiff_t) &dispatch_table[0]
  |.endmacro

  |.macro reloadVfn
  | mov VFN, sVfnRef
  | mov VFN, [VFN]
  |.endmacro

  // sClosureRef = &top_record.closure (closure is field 0, so this is just
  // the top record's address: vm_frames.finish - sizeof(VMCallFrame)).
  // Must be re-derived after any C call that could push frames or grow the
  // vm_frames vector (i.e. anything that can re-enter Scheme).
  |.macro refreshClosureRef
  | mov rcx, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | lea rcx, [rcx - FR_SIZE]
  | mov sClosureRef, rcx
  |.endmacro

  |.macro rebaseCpFromVfn
  | mov r8, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea r8, [r8 + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov r9, sCodeBase
  | mov sCodeBase, r8
  | sub CP, r9
  | add CP, r8
  |.endmacro

  // Inline replacement for native_vm_refresh. The refresh helper just recomputed
  // LOCALS = &gc.vm_stack[sff_offset+5] and STACK = &gc.vm_stack[stack_word_off];
  // all five slow-path apply helpers do this after a call that may have realloced
  // gc.vm_stack. Inlining also preserves rax (the helper's caller must otherwise
  // push/pop the result around the call), so sites drop a push/push/pop/pop pair
  // plus the full SysV call.
  //
  // stack_word_off: caller-provided register holding the post-call stack top
  //   (word index into gc.vm_stack). Clobbers r8 and rsi.
  |.macro inlineFrameRefresh, stack_word_off
  | mov r8, [STATE + NATIVE_VM_STACK_OFF]
  | mov rsi, sSffOffset
  | lea LOCALS, [r8 + rsi*8]
  | lea STACK,  [r8 + stack_word_off*8]
  |.endmacro

  // Same as inlineFrameRefresh but also re-derives sClosureRef from the top
  // frame record. Used by the non-tail apply fallbacks; the tail-apply
  // fallbacks skip it because they jump to op_return, which rederives
  // closure_ref itself. Clobbers r8, rsi, rdi.
  |.macro inlineFrameRefreshFull, stack_word_off
  | inlineFrameRefresh stack_word_off
  | mov rdi, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | lea rdi, [rdi - FR_SIZE]
  | mov sClosureRef, rdi
  |.endmacro

  |.macro restoreAfterStateCall
  | refreshClosureRef
  | reloadDtable
  |.endmacro

  |.macro restoreAfterHelperCall
  | restoreAfterStateCall
  | reloadVfn
  |.endmacro

  |.macro restoreAfterGcHelperCall
  | restoreAfterHelperCall
  | rebaseCpFromVfn
  |.endmacro

  |.macro fetchOperand, dst
  | mov dst, [CP]
  | add CP, 8
  |.endmacro

  |.macro pushReg, src
  | mov [STACK], src
  | add STACK, 8
  |.endmacro

  |.macro popReg, dst
  | sub STACK, 8
  | mov dst, [STACK]
  |.endmacro

  |.macro jumpToOperandTarget, reg
  | mov rcx, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea CP, [rcx + reg*8 + (ptrdiff_t) offsetof(Bytevector, data)]
  | jmp ->dispatch
  |.endmacro

  |.macro jumpIfActiveException, value, scratch
  | test value, value
  | jz >1
  | test value, 3
  | jnz >1
  | mov scratch, [value]
  | and scratch, 2047
  | cmp scratch, (EXCEPTION + Value::EXCEPTION_ACTIVE_BIT)
  | je ->exception_return
  |1:
  |.endmacro

  |.macro pairAccessTop, field_off, err
  | mov rax, [STACK - 8]
  | test rax, rax
  | je err
  | test rax, 3
  | jnz err
  | mov rdx, [rax]
  | movzx rdx, dl
  | cmp rdx, PAIR
  | jne err
  | mov rdx, [rax + field_off]
  | mov [STACK - 8], rdx
  | jmp ->dispatch
  |.endmacro

  // Exp 7: chained pair-access check. Caller sets rax to the current value
  // (first step: rax = [STACK - 8]; subsequent steps: rax = result of prior
  // step). This macro only does the PAIR type-check — on mismatch, stores
  // the offending value back to [STACK - 8] and jumps to `err` (which reads
  // [STACK - 8] to populate the error). On success, falls through with rax
  // unchanged; the caller is responsible for doing `mov rax, [rax +
  // field_off]` afterwards.
  //
  // Using two local labels per expansion would collide when the macro is
  // invoked multiple times in the same procedure (DynASM local labels are
  // reusable across the whole code segment), so we thread the mismatch
  // through a per-caller off-path label the caller chooses.
  |.macro pairCheckTop, err
  | test rax, rax
  | je err
  | test rax, 3
  | jnz err
  | mov rdx, [rax]
  | movzx rdx, dl
  | cmp rdx, PAIR
  | jne err
  |.endmacro

  |.code

  // --- entry -----------------------------------------------------------------
  // Args: rdi=State*, rsi=&fn (vfn_ref), rdx=locals*, rcx=stack*, r8=argc, r9=cp
  // Precondition: the caller has already pushed this session's SESSION_BASE
  // VMCallFrame record onto gc.vm_frames; the entry derives the current frame
  // base and closure pointer from that top record.
  |->entry:
  | push rbx
  | push rbp
  | push r12
  | push r13
  | push r14
  | push r15
  // 72 bytes of per-invocation state plus alignment:
  //   [rsp]    = vfn_ref        (GC-tracked VMFunction slot)
  //   [rsp+8]  = current sff_offset (this frame's base word index in gc.vm_stack)
  //   [rsp+16] = closure_ref    (&top_record.closure in gc.vm_frames)
  //   [rsp+24] = code_base      (current VMFunction->code->data pointer; used
  //                              to rebase CP after a C call that may have
  //                              triggered a GC which moved the Bytevector
  //                              holding the bytecode — see CP_RELOAD below)
  //   [rsp+32] = spare scratch
  //   [rsp+40] = spare scratch
  //   [rsp+48] = spare scratch
  //   [rsp+56] = spare scratch
  //   [rsp+64] = unused padding (keeps total reserve a multiple of 16)
  // Combined with the 6 callee-saved pushes (48 bytes) and the call's return
  // address (8), this leaves rsp at a multiple of 16 — ready for subsequent
  // C `call`s as SysV AMD64 requires.
  | sub rsp, 72
  | mov STATE,  rdi
  | mov sVfnRef, rsi         // vfn_ref (&f.fn)
  | mov VFN,    [rsi]        // VFN = *vfn_ref = VMFunction* (latest)
  | mov LOCALS, rdx
  | mov STACK,  rcx
  | mov ARGC,   r8
  | mov CP,     r9
  // Stash initial code_base. On every C call that can GC we use this to
  // recompute CP via a new_base - old_base delta — mirrors VM2_RESTORE_GC
  // in src/vm.cpp.
  | mov rax, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea rax, [rax + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov sCodeBase, rax
  // Current frame base + closure ref from the session-base record.
  | mov rax, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | lea rax, [rax - FR_SIZE]
  | mov sClosureRef, rax
  | mov rcx, [rax + 8]       // record.frame_base
  | mov sSffOffset, rcx
  | reloadDtable
  // fall through into dispatch

  |->dispatch:
  | mov rax, [CP]
  | add CP, 8
  | jmp qword [DTABLE + rax*8]

  // --- OP_ARGC_EQ ------------------------------------------------------------
  |->op_argc_eq:
  | fetchOperand rax
  | cmp ARGC, rax
  | jne ->argc_error
  | jmp ->dispatch

  // --- OP_PUSH_IMMEDIATE -----------------------------------------------------
  |->op_push_immediate:
  | fetchOperand rax
  | pushReg rax
  | jmp ->dispatch

  // --- OP_ARGC_GTE (S3) ------------------------------------------------------
  |->op_argc_gte:
  | fetchOperand rax
  | cmp ARGC, rax
  | jb ->argc_gte_error
  | jmp ->dispatch

  // --- OP_LOCAL_GET (S3) -----------------------------------------------------
  // LOCAL_GET idx: push locals[idx]
  |->op_local_get:
  | fetchOperand rax
  | mov rdx, [LOCALS + rax*8]
  | pushReg rdx
  | jmp ->dispatch

  // --- OP_LOCAL_SET (S3) -----------------------------------------------------
  // LOCAL_SET idx: locals[idx] = pop
  |->op_local_set:
  | fetchOperand rax
  | popReg rdx
  | mov [LOCALS + rax*8], rdx
  | jmp ->dispatch

  // --- OP_POP (S3) -----------------------------------------------------------
  |->op_pop:
  | sub STACK, 8
  | jmp ->dispatch

  // --- OP_ARGV_REST (S10) ----------------------------------------------------
  // The rest-list has already been built in apply_native_vm's prologue, so
  // this is a no-op — just advance to the next opcode.
  |->op_argv_rest:
  | jmp ->dispatch

  // --- OP_BOX_FROM_LOCAL (S9) -------------------------------------------
  // Push the Box sitting in this frame's box area just past locals.
  |->op_box_from_local:
  | mov edx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | fetchOperand rax
  | add rdx, rax
  | mov rcx, [LOCALS + rdx*8]
  | pushReg rcx
  | jmp ->dispatch

  // --- OP_BOX_FROM_CLOSURE (S9) ------------------------------------------
  // Push closure->captures->data[idx] raw (still-boxed Box*, to be
  // forwarded into a fresh Closure's capture vector by op_close_over).
  |->op_box_from_closure:
  | mov rdx, [rsp + 16]          // closure_ref
  | mov rdx, [rdx]               // Closure* (as heap pointer)
  | mov rdx, [rdx + (ptrdiff_t) offsetof(Closure, captures)]
  | fetchOperand rax
  | mov rcx, [rdx + rax*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | pushReg rcx
  | jmp ->dispatch

  // --- OP_BOX_GET (S9) ---------------------------------------------------
  // idx: push dereferenced capture from closure. Goes through a C helper so
  // we don't re-implement Box's open/closed/pointer branching in asm.
  |->op_box_get:
  | mov rdi, STATE
  | mov rdx, sClosureRef
  | mov rsi, [rdx]               // closure value
  | mov rdx, [CP]
  | add CP, 8
  | mov64 rax, (ptrdiff_t) &native_vm_box_get
  | call rax
  | restoreAfterHelperCall
  | mov [STACK], rax
  | add STACK, 8
  | jmp ->dispatch

  // --- OP_BOX_SET (S9) ---------------------------------------------------
  // idx: closure capture[idx] = pop.
  |->op_box_set:
  | mov rdi, STATE
  | mov rdx, sClosureRef
  | mov rsi, [rdx]               // closure value
  | mov rdx, [CP]
  | add CP, 8
  | sub STACK, 8
  | mov rcx, [STACK]             // val
  | mov64 rax, (ptrdiff_t) &native_vm_box_set
  | call rax
  | restoreAfterHelperCall
  | jmp ->dispatch

  // --- OP_CAPTURE_FROM_LOCAL (display closures) -----------------------------
  // Push locals[idx] raw (no Box indirection). Mirrors op_local_get —
  // the compiler emits this for immutable free-variable slots whose value
  // the enclosing function wants to stash directly into a fresh Closure.
  |->op_capture_from_local:
  | fetchOperand rax
  | mov rdx, [LOCALS + rax*8]
  | pushReg rdx
  | jmp ->dispatch

  // --- OP_CAPTURE_FROM_CLOSURE / OP_CAPTURE_GET (display closures) ----------
  // Single indexed load of current_closure->captures[idx] — no Box
  // open/closed/pointer dispatch. FROM_CLOSURE is emitted in the parent at
  // close-over (forwards a parent's capture into a fresh child Closure);
  // GET is emitted in the child at an access site (the slot holds the
  // value directly). Both ops route here via NATIVE_VM_DISPATCH_OPS.
  |->op_capture_ref:
  | mov rdx, [rsp + 16]          // closure_ref
  | mov rdx, [rdx]               // Closure* (as heap pointer)
  | mov rdx, [rdx + (ptrdiff_t) offsetof(Closure, captures)]
  | fetchOperand rax
  | mov rcx, [rdx + rax*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | pushReg rcx
  | jmp ->dispatch

  // --- OP_CLOSE_OVER (S9) ----------------------------------------------------
  // count: allocate Closure from the top function + `count` capture slots,
  // pop them all, push the fresh Closure. Done in a C helper because
  // allocation + procedure_addr plumbing is non-trivial.
  |->op_close_over:
  | mov rdi, STATE
  | mov rsi, STACK
  | mov rdx, [CP]
  | add CP, 8
  | mov64 rax, (ptrdiff_t) &native_vm_close_over
  | call rax
  | restoreAfterGcHelperCall
  // CP reload — close_over allocates so the bytecode Bytevector may have
  // moved. Uses r8/r9 as scratches; preserves rax (return value).
  // Pop count + 1 (for fn) and push result at the now-top slot.
  | mov rcx, [CP - 8]            // count
  | inc rcx                      // count + 1
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK], rax
  | add STACK, 8
  | jmp ->dispatch

  // --- OP_APPLY_TAIL (S8) ----------------------------------------------------
  // Tail call. For simple fixed-arity VM targets we reuse the current frame
  // in-place. Everything else falls back to a recursive procedure_addr call
  // and then returns through OP_RETURN, preserving correctness.
  |->op_apply_tail:
  | mov rax, [CP]                      // fargc
  | add CP, 8
  | mov rcx, rax
  | shl rcx, 3
  | mov r8, STACK
  | sub r8, rcx                        // args_start
  | mov r9, [r8 - 8]                   // fn value
  | test r9, r9
  | je ->apply_error
  | test r9, 3
  | jnz ->apply_error
  | mov rdx, [r9]
  | test rdx, (ptrdiff_t) Value::VALUE_PROCEDURE_BIT
  | jz ->apply_error
  // Heap type in dl — VMFUNCTION/CLOSURE get the tail-call path, everything
  // else is a direct C call + OP_RETURN.
  | movzx rcx, dl
  | cmp rcx, VMFUNCTION
  | je >1
  | cmp rcx, CLOSURE
  | jne >9
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
  | jmp >2
  |1:
  | mov r10, r9
  |2:
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_NATIVE_VM_BIT
  | jz >9
  // Record-recycling fast path for exact-arity, non-variadic callees
  // (any caller, any depth).
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, min_arity)]
  | cmp ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, max_arity)]
  | jne >9
  // argc == F enters directly (fixed or variadic — a variadic callee with
  // exactly F args gets rest = '() from ->apply_enter_variadic). Otherwise
  // only variadic callees with argc > F may enter; variadic with argc < F
  // bails so the C slow path raises the proper arity exception.
  | cmp rax, rcx
  | je >8
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jz >9
  | cmp rax, rcx
  | jb >9
  |8:
  // In-asm tail call with record recycling — works from ANY depth (nested
  // frames included): the record keeps its return linkage and frame_base, so
  // the eventual OP_RETURN resumes the original caller (or returns to C for
  // a recycled session-base frame). The callee must have min == max arity
  // and be native; the CALLER may be anything. Boxed callees get their
  // Boxes allocated post-entry via ->apply_enter_boxes; variadic callees
  // finish entry via ->apply_enter_variadic.
  | mov [rsp + 32], rax                // spill fargc
  | mov [rsp + 48], r9                 // spill callee fn value
  | mov [rsp + 56], r10                // spill callee VMFunction* (no GC below)
  // args_start as a word offset (survives vm_stack realloc in helpers)
  | mov rcx, [STATE + NATIVE_VM_STACK_OFF]
  | mov rdx, r8
  | sub rdx, rcx
  | shr rdx, 3
  | mov [rsp + 40], rdx
  // Close the caller's still-open boxes before recycling its frame
  // (mirrors apply_vm's vm_close_frame_boxes on tail recycle).
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test ecx, ecx
  | jz >3
  | mov rdi, STATE
  | mov rsi, VFN
  | mov rdx, [rsp + 8]
  | mov64 rax, (ptrdiff_t) &native_vm_close_frame_boxes
  | call rax
  | reloadDtable
  | mov r10, [rsp + 56]
  |3:
  // extent = frame_base + callee local_count + stack_max; climbing past the
  // high-water mark goes through the grow+zero helper.
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | mov esi, dword [r10 + (ptrdiff_t) offsetof(VMFunction, stack_max)]
  | add rcx, rsi
  | add rcx, [rsp + 8]
  | cmp rcx, [STATE + NATIVE_VM_STACK_USED_OFF]
  | jbe >4
  | mov rdi, STATE
  | mov rsi, rcx
  | mov64 rax, (ptrdiff_t) &native_vm_prepare_frame
  | call rax
  | reloadDtable
  | mov r10, [rsp + 56]
  |4:
  // Slide the args down onto the recycled frame's base (dst <= src; the
  // forward copy is overlap-safe).
  | mov rdi, [STATE + NATIVE_VM_STACK_OFF]
  | mov rcx, [rsp + 8]
  | lea LOCALS, [rdi + rcx*8]          // dst = frame base (= callee locals)
  | mov rcx, [rsp + 40]
  | lea rsi, [rdi + rcx*8]             // src = args_start
  | mov rdi, LOCALS
  | mov rcx, [rsp + 32]
  |->apply_tail_move_loop:
  | test rcx, rcx
  | jz ->apply_tail_move_done
  | mov rdx, [rsi]
  | mov [rdi], rdx
  | add rsi, 8
  | add rdi, 8
  | dec rcx
  | jmp ->apply_tail_move_loop
  |->apply_tail_move_done:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_tail_vm_path
  | inc qword [rcx]
  // Recycle the top frame record: same base + return linkage, new closure,
  // frames_lost++. refreshClosureRef re-derives the record pointer (the
  // prepare_frame helper may have moved vm_frames' storage) and leaves it
  // in rcx.
  | refreshClosureRef
  | mov rax, [rsp + 48]
  | mov [rcx], rax                     // record.closure = callee fn
  | inc dword [rcx + 32]               // record.frames_lost++
  | mov r10, [rsp + 56]
  | mov VFN, r10
  | mov rcx, [rsp]
  | mov [rcx], VFN
  | mov ARGC, [rsp + 32]
  // Memset diet: zero only unsupplied locals (rdi sits just past the args).
  // Variadic callees skip the loop — its count goes negative with extras;
  // ->apply_enter_variadic's helper does the slot init instead.
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_tail_zero_done
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | sub rcx, [rsp + 32]
  | xor edx, edx
  |->apply_tail_zero_loop:
  | test rcx, rcx
  | jz ->apply_tail_zero_done
  | mov [rdi], rdx
  | add rdi, 8
  | dec rcx
  | jmp ->apply_tail_zero_loop
  |->apply_tail_zero_done:
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | lea STACK, [LOCALS + rcx*8]
  | mov rax, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea CP, [rax + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov [rsp + 24], CP
  | reloadDtable
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_enter_variadic
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test ecx, ecx
  | jnz ->apply_enter_boxes
  | jmp ->dispatch
  |9:
  // Helper fallback for complex tail calls and all CFUNCTION targets.
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_tail_c_path
  | inc qword [rcx]
  // Compute allow_tail = (top frame record has SESSION_BASE). Tail-flag is
  // only safe at the top-level frame of this apply_native_vm call — in nested
  // fast-path frames the flag would cause apply_native_vm to unwind the
  // wrong level.
  | mov rcx, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | xor r11, r11
  | test dword [rcx - 4], 1            // top record flags & SESSION_BASE
  | setnz r11b                         // allow_tail = 1 iff session-base frame
  // Save the current absolute stack-top word index so we can rebuild STACK
  // after a helper call that may realloc gc.vm_stack.
  | mov rcx, [STATE + NATIVE_VM_STACK_OFF]
  | mov rdx, STACK
  | sub rdx, rcx
  | shr rdx, 3
  | push rdx                           // saved: stack_word_offset_before
  | push rax                           // saved: fargc
  | mov rdi, STATE
  | mov rsi, r9                        // fn value
  | mov rdx, r8                        // args_start
  | mov rcx, rax                       // fargc
  | mov r8, r11                        // allow_tail
  | mov64 rax, (ptrdiff_t) &native_vm_op_apply_tail
  | call rax
  // rax = is_tail, rdx = result
  | mov r8, rax
  | mov r9, rdx
  | pop rcx                            // rcx = fargc
  | pop rdx                            // rdx = stack_word_offset_before
  | test r8, r8
  | jnz ->tail_return_marker
  | mov rax, r9                        // rax = result
  // Rebuild LOCALS/STACK after the helper call; post-apply stack top is
  // old_top - fargc because the result overwrites the function slot.
  | sub rdx, rcx
  | inlineFrameRefresh rdx
  | reloadDtable
  | mov VFN, sVfnRef
  | mov VFN, [VFN]
  | jumpIfActiveException rax, rcx
  |->apply_tail_helper_result_ready:
  | mov [STACK - 8], rax
  | jmp ->op_return

  // --- OP_APPLY (S7) ---------------------------------------------------------
  // APPLY fargc: pop fargc args + fn, call fn->procedure_addr(state, fargc,
  // args, fn_heap). After the call, reload VFN (GC may have moved it),
  // LOCALS/STACK (gc.vm_stack may have been realloc'd by a recursive
  // apply_native_vm), and DTABLE (caller-saved). On exception, return.
  |->op_apply:
  | mov rax, [CP]                      // rax = fargc
  | add CP, 8
  | mov rcx, rax
  | shl rcx, 3                         // rcx = fargc*8
  | mov r8, STACK
  | sub r8, rcx                        // r8 = args_start
  | mov r9, [r8 - 8]                   // r9 = fn value
  | test r9, r9
  | je ->apply_error
  | test r9, 3
  | jnz ->apply_error
  | mov rdx, [r9]
  | test rdx, (ptrdiff_t) Value::VALUE_PROCEDURE_BIT
  | jz ->apply_error
  | movzx rcx, dl
  | cmp rcx, VMFUNCTION
  | je >1
  | cmp rcx, CLOSURE
  | jne ->op_apply_bail_cfunction
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
  | jmp >2
  |1:
  | mov r10, r9
  |2:
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_NATIVE_VM_BIT
  | jz ->op_apply_bail_no_native_bit
  // C1 fast path: VM callees with min == max arity, fixed or variadic.
  // Boxed callees get their Boxes allocated after frame entry via
  // ->apply_enter_boxes; variadic callees finish entry (rest list, slot
  // init, boxes) via ->apply_enter_variadic. argc == F enters directly;
  // otherwise only variadic with argc > F may enter — variadic with
  // argc < F bails so the C slow path raises the proper arity exception.
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, min_arity)]
  | cmp ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, max_arity)]
  | jne ->op_apply_bail_arity_range
  | cmp rax, rcx
  | je >8
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jz ->op_apply_bail_argc_mismatch
  | cmp rax, rcx
  | jb ->op_apply_bail_variadic
  |8:
  // Recursion-depth check + commit (mirrors apply_vm's enter: ordering — on
  // failure the registers still describe the calling frame).
  | mov rcx, [STATE + (ptrdiff_t) offsetof(State, vm_depth)]
  | inc rcx
  | cmp rcx, [STATE + (ptrdiff_t) offsetof(State, recursion_limit)]
  | jae ->recursion_limit_error
  | mov [STATE + (ptrdiff_t) offsetof(State, vm_depth)], rcx
  // Save fargc, args_start word index, and callee fn value across a potential
  // cold-path helper call.
  | mov [rsp + 32], rax
  | mov rcx, [STATE + NATIVE_VM_STACK_OFF]
  | mov rdx, r8
  | sub rdx, rcx
  | shr rdx, 3
  | mov [rsp + 40], rdx
  | mov [rsp + 48], r9
  // Zero-copy: the args (already on the caller's eval stack) become the
  // callee's first locals in place — frame_base = args_start. extent =
  // frame_base + local_count + box_count + stack_max.
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | mov esi, dword [r10 + (ptrdiff_t) offsetof(VMFunction, stack_max)]
  | add rcx, rsi
  | add rdx, rcx                       // rdx = extent
  // Inline only when extent is at or under the high-water mark AND vm_frames
  // has a record slot free; otherwise the helper grows + zeroes both.
  | cmp rdx, [STATE + NATIVE_VM_STACK_USED_OFF]
  | ja >3
  | mov rax, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | cmp rax, [STATE + NATIVE_VM_FRAMES_EOS_OFF]
  | jae >3
  | jmp >4
  |3:
  | mov rdi, STATE
  | mov rsi, rdx                       // extent
  | mov64 rax, (ptrdiff_t) &native_vm_prepare_frame
  | call rax
  | reloadDtable
  |4:
  // Reload callee + stack pointers after any realloc.
  | mov r9, [rsp + 48]
  | mov rdx, [r9]
  | movzx rcx, dl
  | cmp rcx, CLOSURE
  | jne >5
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
  | jmp >6
  |5:
  | mov r10, r9
  |6:
  | mov rdi, [STATE + NATIVE_VM_STACK_OFF]
  | mov r11, [rsp + 40]                // r11 = frame_base (= new sff_offset)
  | lea rsi, [rdi + r11*8]             // rsi = frame base ptr = callee locals
  // Push the callee's VMCallFrame record.
  | mov rcx, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | mov rdx, [rsp + 48]
  | mov [rcx], rdx                     // closure
  | mov [rcx + 8], r11                 // frame_base
  | mov rdx, CP
  | sub rdx, sCodeBase
  | shr rdx, 3
  | mov [rcx + 16], rdx                // return_cp (word offset)
  | mov rdx, [rsp + 40]
  | dec rdx                            // result lands in the fn slot
  | mov [rcx + 24], rdx                // result_slot
  | mov qword [rcx + 32], 0            // frames_lost = 0, flags = 0
  | mov sClosureRef, rcx
  | add rcx, FR_SIZE
  | mov [STATE + NATIVE_VM_FRAMES_FINISH_OFF], rcx
  // Memset diet: args are already the first locals; zero only unsupplied
  // locals and box slots. The eval region is write-before-read and every
  // slot below the high-water mark is GC-scannable already.
  // Variadic callees skip the loop entirely: its count goes NEGATIVE when
  // argc exceeds local_count + box_count; ->apply_enter_variadic's helper
  // does all slot init beyond the args instead.
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_zero_done
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | sub rcx, [rsp + 32]                // local_count + box_count - argc
  | mov rdx, [rsp + 32]
  | lea LOCALS, [rsi + rdx*8]
  | xor edx, edx
  |->apply_zero_loop:
  | test rcx, rcx
  | jz ->apply_zero_done
  | mov [LOCALS], rdx
  | add LOCALS, 8
  | dec rcx
  | jmp ->apply_zero_loop
  |->apply_zero_done:
  // Enter callee frame.
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_vm_path
  | inc qword [rcx]
  | mov VFN, r10
  | mov rcx, [rsp]
  | mov [rcx], VFN
  | mov LOCALS, rsi
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | lea STACK, [LOCALS + rcx*8]
  | mov ARGC, [rsp + 32]
  | mov rax, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea CP, [rax + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov [rsp + 24], CP
  | mov [rsp + 8], r11
  | reloadDtable
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_enter_variadic
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test ecx, ecx
  | jnz ->apply_enter_boxes
  | jmp ->dispatch
  |9:
  |->op_apply_slow:
  // Compute absolute stack-top word index relative to gc.vm_stack, save it.
  // This survives a callee realloc'ing gc.vm_stack.
  | mov rcx, [STATE + (ptrdiff_t)(offsetof(State, gc) + offsetof(GCCommon, vm_stack))]
  | mov rdx, STACK
  | sub rdx, rcx
  | shr rdx, 3                         // rdx = STACK_word_offset (before call)
  | push rdx                           // saved: stack_word_offset
  | push rax                           // saved: fargc
  // Setup call: procedure_addr(state, fargc, args_start, fn_heap)
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_path
  | inc qword [rcx]
  | mov rdi, STATE
  | mov rsi, rax                       // fargc
  | mov rdx, r8                        // args_start
  | mov rcx, r9                        // fn heap
  | mov rax, [r9 + (ptrdiff_t) offsetof(Procedure, procedure_addr)]
  | call rax
  // rax = result Value
  | pop rcx                            // rcx = fargc
  | pop rdx                            // rdx = stack_word_offset_before
  // stack_word_offset_after = before - fargc
  | sub rdx, rcx
  | inlineFrameRefreshFull rdx
  | reloadDtable
  | mov VFN, sVfnRef
  | mov VFN, [VFN]
  // CP reload — the invoked procedure may have allocated (or recursively
  // entered apply_native_vm), so the bytecode Bytevector may have moved.
  | rebaseCpFromVfn
  // Active-exception check (immediate + EXCEPTION + ACTIVE)
  | test rax, rax
  | jz >1
  | test rax, 3
  | jnz >1
  | mov rdx, [rax]
  | and rdx, 2047
  | cmp rdx, (EXCEPTION + Value::EXCEPTION_ACTIVE_BIT)
  | je ->exception_return
  |1:
  | mov [STACK - 8], rax
  | jmp ->dispatch

  // --- op_apply bail-reason histogram (are-8qgc diagnostic) -----------------
  // Each trampoline records why the C1 fast path was rejected, then falls
  // into the existing C-fallback slow path. Cold paths only — no fast-path
  // cost. r9/r8/rax are preserved by the jcc itself, so the slow path's
  // register expectations (rax=fargc, r8=args_start, r9=fn) are intact.
  |->op_apply_bail_cfunction:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_cfunction
  | inc qword [rcx]
  | jmp ->op_apply_slow
  |->op_apply_bail_no_native_bit:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_no_native_bit
  | inc qword [rcx]
  | jmp ->op_apply_slow
  |->op_apply_bail_arity_range:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_arity_range
  | inc qword [rcx]
  | jmp ->op_apply_slow
  |->op_apply_bail_argc_mismatch:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_argc_mismatch
  | inc qword [rcx]
  | jmp ->op_apply_slow
  |->op_apply_bail_variadic:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_c_variadic
  | inc qword [rcx]
  | jmp ->op_apply_slow

  // --- Boxed frame entry (cold) ----------------------------------------------
  // The just-entered frame has mutable captures: allocate its open Boxes via
  // the C helper. The frame is fully committed (record pushed or recycled,
  // locals + box slots zeroed, registers and stack slots set), so the only
  // post-call fixups are the GC-movable derivations: VFN via the traced
  // *vfn_ref and CP/sCodeBase (the bytecode Bytevector may move). LOCALS and
  // STACK point into vm_stack, which the GC never moves. ARGC (r10,
  // caller-saved) is preserved for OP_ARGC_EQ; the scratch slots are dead at
  // entry-complete so sScratch0 is free.
  |->apply_enter_boxes:
  | mov sScratch0, ARGC
  | mov rdi, STATE
  | mov64 rax, (ptrdiff_t) &native_vm_alloc_frame_boxes
  | call rax
  | restoreAfterGcHelperCall
  | mov ARGC, sScratch0
  | jmp ->dispatch

  // --- Variadic frame entry (cold) ---------------------------------------------
  // The just-entered frame is variadic: the C helper builds the rest list,
  // finishes slot init (the fast path skipped its zero loop), and allocates
  // any open Boxes. Same commit/restore discipline as ->apply_enter_boxes.
  // ARGC must still be the ORIGINAL argc when the callee's OP_ARGC_GTE
  // runs, hence the sScratch0 save/reload (ARGC is r10, caller-saved).
  |->apply_enter_variadic:
  | mov sScratch0, ARGC
  | mov rdi, STATE
  | mov rsi, ARGC
  | mov64 rax, (ptrdiff_t) &native_vm_enter_variadic
  | call rax
  | restoreAfterGcHelperCall
  | mov ARGC, sScratch0
  | jmp ->dispatch

  // --- OP_APPLY_LOCAL (exp 8) -----------------------------------------------
  // APPLY_LOCAL idx fargc: like OP_APPLY but the callee is loaded from
  // LOCALS[idx] rather than popped from the operand stack. The stack contains
  // only [arg1 … argN] — there is NO fn slot. After the call the result
  // replaces arg1 and STACK moves to args_start+1.
  // Interpreter counterpart: src/vm.cpp OP_APPLY_LOCAL (around line 675).
  |->op_apply_local:
  | fetchOperand rcx                   // rcx = local idx
  | mov r9, [LOCALS + rcx*8]           // r9 = fn value (from locals[idx])
  | fetchOperand rax                   // rax = fargc
  | mov rcx, rax
  | shl rcx, 3                         // rcx = fargc*8
  | mov r8, STACK
  | sub r8, rcx                        // r8 = args_start = STACK - fargc*8
  | test r9, r9
  | je ->apply_error
  | test r9, 3
  | jnz ->apply_error
  | mov rdx, [r9]
  | test rdx, (ptrdiff_t) Value::VALUE_PROCEDURE_BIT
  | jz ->apply_error
  | movzx rcx, dl
  | cmp rcx, VMFUNCTION
  | je >1
  | cmp rcx, CLOSURE
  | jne ->op_apply_local_bail_cfunction
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
  | jmp >2
  |1:
  | mov r10, r9
  |2:
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_NATIVE_VM_BIT
  | jz ->op_apply_local_bail_no_native_bit
  // C1 fast path: VM callees with min == max arity, fixed or variadic
  // (boxed OK) — see op_apply for the check-chain reasoning.
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, min_arity)]
  | cmp ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, max_arity)]
  | jne ->op_apply_local_bail_arity_range
  | cmp rax, rcx
  | je >8
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jz ->op_apply_local_bail_argc_mismatch
  | cmp rax, rcx
  | jb ->op_apply_local_bail_variadic
  |8:
  // Recursion-depth check + commit (see op_apply).
  | mov rcx, [STATE + (ptrdiff_t) offsetof(State, vm_depth)]
  | inc rcx
  | cmp rcx, [STATE + (ptrdiff_t) offsetof(State, recursion_limit)]
  | jae ->recursion_limit_error
  | mov [STATE + (ptrdiff_t) offsetof(State, vm_depth)], rcx
  | mov [rsp + 32], rax                // spill fargc
  | mov rcx, [STATE + NATIVE_VM_STACK_OFF]
  | mov rdx, r8
  | sub rdx, rcx
  | shr rdx, 3
  | mov [rsp + 40], rdx                // spill args_start word offset
  | mov [rsp + 48], r9                 // spill callee fn value
  // Zero-copy frame entry: see op_apply. frame_base = args_start.
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | mov esi, dword [r10 + (ptrdiff_t) offsetof(VMFunction, stack_max)]
  | add rcx, rsi
  | add rdx, rcx                       // rdx = extent
  | cmp rdx, [STATE + NATIVE_VM_STACK_USED_OFF]
  | ja >3
  | mov rax, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | cmp rax, [STATE + NATIVE_VM_FRAMES_EOS_OFF]
  | jae >3
  | jmp >4
  |3:
  | mov rdi, STATE
  | mov rsi, rdx                       // extent
  | mov64 rax, (ptrdiff_t) &native_vm_prepare_frame
  | call rax
  | reloadDtable
  |4:
  | mov r9, [rsp + 48]
  | mov rdx, [r9]
  | movzx rcx, dl
  | cmp rcx, CLOSURE
  | jne >5
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
  | jmp >6
  |5:
  | mov r10, r9
  |6:
  | mov rdi, [STATE + NATIVE_VM_STACK_OFF]
  | mov r11, [rsp + 40]                // r11 = frame_base (= new sff_offset)
  | lea rsi, [rdi + r11*8]             // rsi = frame base ptr = callee locals
  // Push the callee's VMCallFrame record.
  // NOTE: result_slot has no `dec` — the fused APPLY_LOCAL has no fn slot on
  // the stack, so the result slot IS args_start (where arg1 was).
  | mov rcx, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | mov rdx, [rsp + 48]
  | mov [rcx], rdx                     // closure
  | mov [rcx + 8], r11                 // frame_base
  | mov rdx, CP
  | sub rdx, sCodeBase
  | shr rdx, 3
  | mov [rcx + 16], rdx                // return_cp (word offset)
  | mov rdx, [rsp + 40]
  | mov [rcx + 24], rdx                // result_slot
  | mov qword [rcx + 32], 0            // frames_lost = 0, flags = 0
  | mov sClosureRef, rcx
  | add rcx, FR_SIZE
  | mov [STATE + NATIVE_VM_FRAMES_FINISH_OFF], rcx
  // Memset diet: zero only unsupplied locals and box slots; variadic
  // callees skip the loop — negative count (see op_apply).
  | test qword [r10], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_local_zero_done
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | sub rcx, [rsp + 32]                // local_count + box_count - argc
  | mov rdx, [rsp + 32]
  | lea LOCALS, [rsi + rdx*8]
  | xor edx, edx
  |->apply_local_zero_loop:
  | test rcx, rcx
  | jz ->apply_local_zero_done
  | mov [LOCALS], rdx
  | add LOCALS, 8
  | dec rcx
  | jmp ->apply_local_zero_loop
  |->apply_local_zero_done:
  // Enter callee frame.
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_vm_path
  | inc qword [rcx]
  | mov VFN, r10
  | mov rcx, [rsp]
  | mov [rcx], VFN
  | mov LOCALS, rsi
  | mov ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [r10 + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | lea STACK, [LOCALS + rcx*8]
  | mov ARGC, [rsp + 32]
  | mov rax, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea CP, [rax + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov [rsp + 24], CP
  | mov [rsp + 8], r11
  | reloadDtable
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_enter_variadic
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test ecx, ecx
  | jnz ->apply_enter_boxes
  | jmp ->dispatch

  // Helper fallback (CFUNCTION / non-VM-native callees).
  // rax = fargc, r8 = args_start, r9 = fn value. Stack still holds the
