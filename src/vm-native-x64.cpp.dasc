  // Tail variant of OP_APPLY_LOCAL. Fast-path in-place frame reuse matches
  // op_apply_tail; the only changes are where we get the fn (LOCALS[idx]) and
  // that the operand stack has no fn slot.
  // Interpreter counterpart: src/vm.cpp OP_APPLY_TAIL_LOCAL (around line 696).
  |->op_apply_tail_local:
  | fetchOperand rcx                   // rcx = local idx
  | mov r9, [LOCALS + rcx*8]           // r9 = fn value
  | fetchOperand rax                   // rax = fargc
  | mov rcx, rax
  | shl rcx, 3
  | mov r8, STACK
  | sub r8, rcx                        // r8 = args_start
  | test r9, r9
  | je ->apply_error
  | test r9, 3
  | jnz ->apply_error
  | mov rdx, [r9]
  | test rdx, (ptrdiff_t) Value::VALUE_PROCEDURE_BIT
  | jz ->apply_error
  | movzx rcx, dl
  | cmp rcx, VMFUNCTION
  | je >1
  | cmp rcx, CLOSURE
  | jne >9
  | mov r10, [r9 + (ptrdiff_t) offsetof(Closure, function)]
