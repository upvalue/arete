  | mov rdi, STATE
  | mov rsi, rcx
  | mov64 rax, (ptrdiff_t) &native_vm_prepare_frame
  | call rax
  | reloadDtable
  | mov r10, [rsp + 56]
  |4:
  // Slide the args down onto the recycled frame's base (forward copy).
  | mov rdi, [STATE + NATIVE_VM_STACK_OFF]
  | mov rcx, [rsp + 8]
  | lea LOCALS, [rdi + rcx*8]          // dst = frame base (= callee locals)
  | mov rcx, [rsp + 40]
  | lea rsi, [rdi + rcx*8]             // src = args_start
  | mov rdi, LOCALS
  | mov rcx, [rsp + 32]
  |->apply_tail_global_move_loop:
  | test rcx, rcx
  | jz ->apply_tail_global_move_done
  | mov rdx, [rsi]
  | mov [rdi], rdx
  | add rsi, 8
  | add rdi, 8
  | dec rcx
  | jmp ->apply_tail_global_move_loop
  |->apply_tail_global_move_done:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_tail_vm_path
  | inc qword [rcx]
  // Recycle the top frame record (see op_apply_tail).
  | refreshClosureRef
  | mov rax, [rsp + 48]
  | mov [rcx], rax                     // record.closure = callee fn
  | inc dword [rcx + 32]               // record.frames_lost++
  | mov r10, [rsp + 56]
  | mov VFN, r10
  | mov rcx, [rsp]
  | mov [rcx], VFN
  | mov ARGC, [rsp + 32]
  // Memset diet: zero only unsupplied locals; variadic callees skip the
  // loop — negative count (see op_apply_tail).
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_tail_global_zero_done
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | sub rcx, [rsp + 32]
  | xor edx, edx
  |->apply_tail_global_zero_loop:
  | test rcx, rcx
  | jz ->apply_tail_global_zero_done
  | mov [rdi], rdx
  | add rdi, 8
  | dec rcx
  | jmp ->apply_tail_global_zero_loop
  |->apply_tail_global_zero_done:
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, local_count)]
  | add ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | lea STACK, [LOCALS + rcx*8]
  | mov rax, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea CP, [rax + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov [rsp + 24], CP
  | reloadDtable
  | test qword [VFN], (ptrdiff_t) Value::VMFUNCTION_VARIABLE_ARITY_BIT
  | jnz ->apply_enter_variadic
  | mov ecx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test ecx, ecx
  | jnz ->apply_enter_boxes
  | jmp ->dispatch
  |9:
  | mov64 rcx, (ptrdiff_t) &native_vm_stat_apply_tail_c_path
  | inc qword [rcx]
  | mov rcx, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | xor r11, r11
  | test dword [rcx - 4], 1            // top record flags & SESSION_BASE
  | setnz r11b
  | mov rcx, [STATE + NATIVE_VM_STACK_OFF]
  | mov rdx, STACK
  | sub rdx, rcx
  | shr rdx, 3
  | push rdx
  | push rax
  | mov rdi, STATE
  | mov rsi, r9
  | mov rdx, r8
  | mov rcx, rax
  | mov r8, r11
  | mov64 rax, (ptrdiff_t) &native_vm_op_apply_tail
  | call rax
  | mov r8, rax
  | mov r9, rdx
  | pop rcx
  | pop rdx
  | test r8, r8
  | jnz ->tail_return_marker
  | mov rax, r9
  | sub rdx, rcx
  | inc rdx
  | inlineFrameRefresh rdx
  | reloadDtable
  | mov VFN, sVfnRef
  | mov VFN, [VFN]
  | jumpIfActiveException rax, rcx
  | mov [STACK - 8], rax
  | jmp ->op_return

  // --- OP_FX_ADD (S6) --------------------------------------------------------
  // Fixnum addition. Type-check skipped — compiler only emits fx+ on arguments
  // it knows are fixnums.
  // (a<<1|1) + (b<<1|1) = ((a+b)<<1)+2; we want ((a+b)<<1)+1, so subtract 1.
  |->op_fx_add:
  | mov rax, [STACK - 8]
  | mov rdx, [STACK - 16]
  | add rax, rdx
  | sub rax, 1
  | mov [STACK - 16], rax
  | sub STACK, 8
  | jmp ->dispatch

  // --- OP_FX_SUB (S6) --------------------------------------------------------
  // (a<<1|1) - (b<<1|1) = (a-b)<<1; we want ((a-b)<<1)+1, so add 1.
  |->op_fx_sub:
  | mov rax, [STACK - 16]
  | mov rdx, [STACK - 8]
  | sub rax, rdx
  | add rax, 1
  | mov [STACK - 16], rax
  | sub STACK, 8
  | jmp ->dispatch

  // --- OP_FX_LT (S6) ---------------------------------------------------------
  // Both operands have the same tag bit; signed compare works directly on
  // the tagged representation.
  |->op_fx_lt:
  | mov rax, [STACK - 16]
  | mov rdx, [STACK - 8]
  | cmp rax, rdx
  | mov rax, C_FALSE
  | mov rcx, C_TRUE
  | cmovl rax, rcx
  | mov [STACK - 16], rax
  | sub STACK, 8
  | jmp ->dispatch

  // --- OP_EQ (S6) ------------------------------------------------------------
  |->op_eq:
  | mov rax, [STACK - 16]
  | mov rdx, [STACK - 8]
  | cmp rax, rdx
  | mov rax, C_FALSE
  | mov rcx, C_TRUE
  | cmove rax, rcx
  | mov [STACK - 16], rax
  | sub STACK, 8
  | jmp ->dispatch

  // --- OP_NOT (S6) -----------------------------------------------------------
  |->op_not:
  | mov rax, [STACK - 8]
  | xor rdx, rdx
  | mov rcx, C_TRUE
  | test rax, rax
  | cmovz rdx, rcx
  | mov [STACK - 8], rdx
  | jmp ->dispatch

  // --- OP_FIXNUMP (S6) -------------------------------------------------------
  // fixnum? iff bits & 1. Shifting the tag bit left by 1 converts 1->2 (C_TRUE)
  // and 0->0 (C_FALSE), avoiding a branch.
  |->op_fixnump:
  | mov rax, [STACK - 8]
  | and rax, 1
  | shl rax, 1
  | mov [STACK - 8], rax
  | jmp ->dispatch

  // --- OP_VALUE_TYPE (are-8qgc) --------------------------------------------
  // Pop v, push (fixnum) v.type_unsafe(). Mirrors Value::type_unsafe:
  //   bits & 3 == 0 -> if bits == 0 then CONSTANT, else heap->get_type()
  //   bits & 1     -> FIXNUM
  //   else         -> CONSTANT
  // Result is fixnum-tagged: ((type << 1) | 1).
  |->op_value_type:
  | mov rax, [STACK - 8]
  | test rax, 3
  | jz >2                                // heap or zero
  | test rax, 1
  | jz >1                                // bit 1 set, bit 0 clear -> CONSTANT
  | mov rax, ((FIXNUM << 1) | 1)
  | jmp >3
  |1:
  | mov rax, ((CONSTANT << 1) | 1)
  | jmp >3
  |2:
  | test rax, rax
  | jz <1                                // rax == 0 -> CONSTANT
  | movzx rax, byte [rax]                // type tag is low 8 bits of header
  | shl rax, 1
  | or rax, 1
  |3:
  | mov [STACK - 8], rax
  | jmp ->dispatch

  // --- OP_VALUE_HEADER_BIT (are-8qgc) --------------------------------------
  // Pop bit-idx (fixnum) and v (heap), push (#t/#f). bit-idx is fixnum 0..63;
  // result is true iff (heap[v]->header >> bit-idx) & 1. Errors when bit-idx
  // is not a fixnum or v is an immediate.
  |->op_value_header_bit:
  | mov rax, [STACK - 16]                // v
  | mov rcx, [STACK - 8]                 // bit-idx (fixnum-tagged)
  | sub STACK, 8                         // net pop one
  | test rcx, 1
  | jz ->value_header_bit_nonfixnum
  | test rax, rax
  | jz ->value_header_bit_immediate
  | test rax, 3
  | jnz ->value_header_bit_immediate
  | shr rcx, 1                           // decode fixnum to bit index
  | mov rdx, [rax]                       // header word
  | shr rdx, cl                          // (header >> bit-idx); cl is count
  | and rdx, 1                           // isolate bit
  | shl rdx, 1                           // 0/1 -> 0/2 (C_FALSE / C_TRUE)
  | mov [STACK - 8], rdx
  | jmp ->dispatch

  // --- OP_CAR / OP_CDR (S6) --------------------------------------------------
  // Type-check: heap pointer, not immediate, heap->get_type() == PAIR.
  // On mismatch dive into native_vm_pair_error with the offending value.
  |->op_car:
  | pairAccessTop NATIVE_VM_PAIR_CAR_OFF, ->car_error

  |->op_cdr:
  | pairAccessTop NATIVE_VM_PAIR_CDR_OFF, ->cdr_error

  // --- Exp 7: fused composite pair accessors ----------------------------------
  // Each performs 2 (or 3 for CADDR) PAIR-type-checked dereferences inline
  // with a single opcode dispatch. On a non-pair intermediate, the per-op
  // error trampoline stores the offender to [STACK - 8] (so the shared
  // car_error/cdr_error trampolines can read it there) and jumps to the
  // correct shared handler. Error-tag names the step that tripped (CADR's
  // cdr step traps to cdr_error; its car step to car_error).

  |->op_cadr:
  // (car (cdr X))
  | mov rax, [STACK - 8]
  | pairCheckTop ->cadr_cdr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | pairCheckTop ->cadr_car_err
  | mov rax, [rax + NATIVE_VM_PAIR_CAR_OFF]
  | mov [STACK - 8], rax
  | jmp ->dispatch
  |->cadr_cdr_err:
  | mov [STACK - 8], rax
  | jmp ->cdr_error
  |->cadr_car_err:
  | mov [STACK - 8], rax
  | jmp ->car_error

  |->op_cddr:
  // (cdr (cdr X))
  | mov rax, [STACK - 8]
  | pairCheckTop ->cddr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | pairCheckTop ->cddr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | mov [STACK - 8], rax
  | jmp ->dispatch
  |->cddr_err:
  | mov [STACK - 8], rax
  | jmp ->cdr_error

  |->op_caar:
  // (car (car X))
  | mov rax, [STACK - 8]
  | pairCheckTop ->caar_err
  | mov rax, [rax + NATIVE_VM_PAIR_CAR_OFF]
  | pairCheckTop ->caar_err
  | mov rax, [rax + NATIVE_VM_PAIR_CAR_OFF]
  | mov [STACK - 8], rax
  | jmp ->dispatch
  |->caar_err:
  | mov [STACK - 8], rax
  | jmp ->car_error

  |->op_cdar:
  // (cdr (car X))
  | mov rax, [STACK - 8]
  | pairCheckTop ->cdar_car_err
  | mov rax, [rax + NATIVE_VM_PAIR_CAR_OFF]
  | pairCheckTop ->cdar_cdr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | mov [STACK - 8], rax
  | jmp ->dispatch
  |->cdar_car_err:
  | mov [STACK - 8], rax
  | jmp ->car_error
  |->cdar_cdr_err:
  | mov [STACK - 8], rax
  | jmp ->cdr_error

  |->op_caddr:
  // (car (cdr (cdr X)))
  | mov rax, [STACK - 8]
  | pairCheckTop ->caddr_cdr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | pairCheckTop ->caddr_cdr_err
  | mov rax, [rax + NATIVE_VM_PAIR_CDR_OFF]
  | pairCheckTop ->caddr_car_err
  | mov rax, [rax + NATIVE_VM_PAIR_CAR_OFF]
  | mov [STACK - 8], rax
  | jmp ->dispatch
  |->caddr_cdr_err:
  | mov [STACK - 8], rax
  | jmp ->cdr_error
  |->caddr_car_err:
  | mov [STACK - 8], rax
  | jmp ->car_error

  // --- OP_TYPE_CHECK (S6) ----------------------------------------------------
  // TYPE_CHECK tipe: pop v, push Value(v.type() == tipe).
  |->op_type_check:
  | mov rdi, [STACK - 8]
  | mov rsi, [CP]
  | add CP, 8
  | mov64 rax, (ptrdiff_t) &native_vm_op_type_check
  | call rax
  | restoreAfterHelperCall
  | mov [STACK - 8], rax
  | jmp ->dispatch

  // --- OP_ADD / OP_SUB / OP_LT (S6) -----------------------------------------
  // Variadic. Helper takes (state, argc, stack-argc), returns result value
  // or an active exception. On success we write the result at stack[-argc]
  // and bring STACK down by (argc-1). On exception we return the exception.
  //
  // Two-level fast path:
  //   argc == 2 fixnum: ~13 insns inline (dominant case in fib/tak/interp).
  //   argc >= 3 fixnum: loop that accumulates bits; subtract (argc-1) at end.
  // Non-fixnum or argc 0 falls through to the variadic C helper.
  |->op_add:
  | mov rax, [CP]
  | cmp rax, 2
  | jne >3                     // not binary: try variadic or helper
  | mov r8, [STACK - 16]
  | mov rdi, [STACK - 8]
  | mov rcx, r8
  | and rcx, rdi
  | test rcx, 1
  | jz >2
  | add CP, 8
  | add r8, rdi
  | sub r8, 1
  | mov [STACK - 16], r8
  | sub STACK, 8
  | jmp ->dispatch
  |3:
  | test rax, rax
  | jz >2
  | mov rcx, rax
  | shl rcx, 3
  | mov rdx, STACK
  | sub rdx, rcx               // args_start
  | xor r8, r8
  | mov r9, rax
  |4:
  | mov rdi, [rdx]
  | test rdi, 1
  | jz >2
  | add r8, rdi
  | add rdx, 8
  | dec r9
  | jnz <4
  | lea rcx, [rax - 1]
  | sub r8, rcx
  | add CP, 8
  | mov rcx, rax
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK - 8], r8
  | jmp ->dispatch
  |2:
  | mov rdi, STATE
  | mov rsi, [CP]              // argc
  | add CP, 8
  | mov rcx, rsi
  | shl rcx, 3                 // argc * 8
  | mov rdx, STACK
  | sub rdx, rcx               // rdx = stack top - argc*8
  | mov64 rax, (ptrdiff_t) &native_vm_op_add
  | call rax
  | restoreAfterGcHelperCall
  // CP reload — helper may have allocated a flonum.
  | mov rcx, [CP - 8]          // argc (re-read operand)
  | jumpIfActiveException rax, rdx
  |1:
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK - 8], rax
  | jmp ->dispatch

  |->op_sub:
  | mov rax, [CP]
  | cmp rax, 2
  | jne >3
  | mov r8, [STACK - 16]
  | mov rdi, [STACK - 8]
  | mov rcx, r8
  | and rcx, rdi
  | test rcx, 1
  | jz >2
  | add CP, 8
  | sub r8, rdi
  | add r8, 1
  | mov [STACK - 16], r8
  | sub STACK, 8
  | jmp ->dispatch
  |3:
  | cmp rax, 2
  | jl >2                      // argc 0 or 1: helper
  | mov rcx, rax
  | shl rcx, 3
  | mov rdx, STACK
  | sub rdx, rcx
  | mov r8, [rdx]
  | test r8, 1
  | jz >2
  | add rdx, 8
  | mov r9, rax
  | dec r9
  |4:
  | mov rdi, [rdx]
  | test rdi, 1
  | jz >2
  | sub r8, rdi
  | add rdx, 8
  | dec r9
  | jnz <4
  | lea rcx, [rax - 1]
  | add r8, rcx
  | add CP, 8
  | mov rcx, rax
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK - 8], r8
  | jmp ->dispatch
  |2:
  | mov rdi, STATE
  | mov rsi, [CP]
  | add CP, 8
  | mov rcx, rsi
  | shl rcx, 3
  | mov rdx, STACK
  | sub rdx, rcx
  | mov64 rax, (ptrdiff_t) &native_vm_op_sub
  | call rax
  | restoreAfterGcHelperCall
  // CP reload — helper may have allocated a flonum.
  | mov rcx, [CP - 8]
  | jumpIfActiveException rax, rdx
  |1:
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK - 8], rax
  | jmp ->dispatch

  |->op_lt:
  | mov rax, [CP]
  | cmp rax, 2
  | jne >3
  | mov r8, [STACK - 16]
  | mov rdi, [STACK - 8]
  | mov rcx, r8
  | and rcx, rdi
  | test rcx, 1
  | jz >2
  | add CP, 8
  | cmp r8, rdi
  | mov64 rax, (ptrdiff_t) C_FALSE
  | mov64 rcx, (ptrdiff_t) C_TRUE
  | cmovl rax, rcx
  | mov [STACK - 16], rax
  | sub STACK, 8
  | jmp ->dispatch
  |3:
  | cmp rax, 2
  | jl >2                      // argc 0 or 1: helper handles
  | mov rcx, rax
  | shl rcx, 3
  | mov rdx, STACK
  | sub rdx, rcx
  | mov r8, [rdx]
  | test r8, 1
  | jz >2
  | mov r9, rax
  | dec r9
  |4:
  | mov rdi, [rdx + 8]
  | test rdi, 1
  | jz >2
  | cmp r8, rdi
  | jge >5
  | mov r8, rdi
  | add rdx, 8
  | dec r9
  | jnz <4
  | add CP, 8
  | mov rcx, rax
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov64 rcx, (ptrdiff_t) C_TRUE
  | mov [STACK - 8], rcx
  | jmp ->dispatch
  |5:
  // Short-circuit #f — but to match apply_vm's semantics we must still have
  // validated later args as fixnums. If there are unchecked args, fall back
  // to the helper (which raises type errors properly).
  | cmp r9, 1
  | jg >2                      // more unchecked pairs -> helper
  | add CP, 8
  | mov rcx, rax
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov64 rcx, (ptrdiff_t) C_FALSE
  | mov [STACK - 8], rcx
  | jmp ->dispatch
  |2:
  | mov rdi, STATE
  | mov rsi, [CP]
  | add CP, 8
  | mov rcx, rsi
  | shl rcx, 3
  | mov rdx, STACK
  | sub rdx, rcx
  | mov64 rax, (ptrdiff_t) &native_vm_op_lt
  | call rax
  | restoreAfterGcHelperCall
  // CP reload — lt is non-allocating on the fast path but on the fallback
  // exception path (calls make_exception) it can. Cheap to do unconditionally.
  | mov rcx, [CP - 8]
  | jumpIfActiveException rax, rdx
  |1:
  | dec rcx
  | shl rcx, 3
  | sub STACK, rcx
  | mov [STACK - 8], rax
  | jmp ->dispatch

  // --- OP_GLOBAL_GET (S5) ----------------------------------------------------
  // GLOBAL_GET idx: symbol = vfn->constants->data[idx]; push symbol->value.
  // Undefined value raises an exception carrying the symbol name.
  |->op_global_get:
  | mov rcx, [VFN + (ptrdiff_t) offsetof(VMFunction, constants)]
  | fetchOperand rax
  | mov rdx, [rcx + rax*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | mov rax, [rdx + (ptrdiff_t) offsetof(Symbol, value)]
  | cmp rax, C_UNDEFINED
  | je ->global_undefined
  | pushReg rax
  | jmp ->dispatch

  // --- OP_GLOBAL_SET (S5) ----------------------------------------------------
  // GLOBAL_SET err_on_undefined key_idx: symbol->value = pop, set ROOT bit.
  |->op_global_set:
  | mov rax, [CP]
  | add CP, 8
  | mov rcx, [CP]
  | add CP, 8
  | mov rdx, [VFN + (ptrdiff_t) offsetof(VMFunction, constants)]
  | mov rdx, [rdx + rcx*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | sub STACK, 8
  | mov rcx, [STACK]
  | test rax, rax
  | jz >1
  | mov r8, [rdx + (ptrdiff_t) offsetof(Symbol, value)]
  | cmp r8, C_UNDEFINED
  | je ->set_undefined_error
  |1:
  | mov [rdx + (ptrdiff_t) offsetof(Symbol, value)], rcx
  | mov rax, [rdx]
  | test rax, (ptrdiff_t) Value::SYMBOL_ROOT_BIT
  | jnz >2
  | or qword [rdx], (ptrdiff_t) Value::SYMBOL_ROOT_BIT
  |2:
  | jmp ->dispatch

  // --- OP_JUMP (S4) ----------------------------------------------------------
  // JUMP target: cp = code_base + target (word offset)
  |->op_jump:
  | mov rax, [CP]
  | jumpToOperandTarget rax

  // --- OP_JUMP_WHEN (S4) -----------------------------------------------------
  // JUMP_WHEN target: if stack[-1] == C_FALSE (0), jump; does NOT pop.
  |->op_jump_when:
  | fetchOperand rax
  | mov rdx, [STACK - 8]
  | test rdx, rdx
  | jnz ->dispatch
  | jumpToOperandTarget rax

  // --- OP_JUMP_WHEN_POP (S4) -------------------------------------------------
  // Same as JUMP_WHEN but pops the stack unconditionally.
  |->op_jump_when_pop:
  | fetchOperand rax
  | sub STACK, 8
  | mov rdx, [STACK]
  | test rdx, rdx
  | jnz ->dispatch
  | jumpToOperandTarget rax

  // --- OP_JUMP_UNLESS (S4) ---------------------------------------------------
  // JUMP_UNLESS target: if stack[-1] != C_FALSE, jump; does NOT pop.
  |->op_jump_unless:
  | fetchOperand rax
  | mov rdx, [STACK - 8]
  | test rdx, rdx
  | jz ->dispatch
  | jumpToOperandTarget rax

  // --- OP_JUMP_IF_NOT_NIL (exp 3) --------------------------------------------
  // Fused null?+jump: pop stack; jump to target iff popped value != C_NIL.
  // Replaces push-immediate '(); eq?; jump-when-pop L in (if (null? X) ...).
  |->op_jump_if_not_nil:
  | fetchOperand rax
  | sub STACK, 8
  | mov rdx, [STACK]
  | cmp rdx, C_NIL
  | je ->dispatch
  | jumpToOperandTarget rax

  // --- OP_JUMP_IF_NIL (exp 3) ------------------------------------------------
  // Fused (not (null? X))+jump: pop stack; jump to target iff popped value == C_NIL.
  |->op_jump_if_nil:
  | fetchOperand rax
  | sub STACK, 8
  | mov rdx, [STACK]
  | cmp rdx, C_NIL
  | jne ->dispatch
  | jumpToOperandTarget rax

  // --- OP_JUMP_IF_NOT_PAIR (exp 3b) ------------------------------------------
  // Fused pair?+jump: pop stack; jump to target iff popped value is NOT a pair.
  // Replaces (type-check PAIR; jump-when-pop L) used by (if (pair? X) ...).
  // Pair test: rdx != 0 AND (rdx & 3) == 0 AND heap->get_type() == PAIR.
  // Treat any failed precondition as "not a pair" → take the jump.
  |->op_jump_if_not_pair:
  | fetchOperand rax
  | sub STACK, 8
  | mov rdx, [STACK]
  | test rdx, rdx
  | je >1               // immediate 0 → not a pair → jump
  | test rdx, 3
  | jnz >1              // fixnum/constant tag bits → not a pair → jump
  | mov rcx, [rdx]
  | movzx rcx, cl
  | cmp rcx, PAIR
  | jne >1              // heap but wrong type → not a pair → jump
  | jmp ->dispatch      // is a pair → fall through (no jump)
  |1:
  | jumpToOperandTarget rax

  // --- OP_JUMP_IF_PAIR (exp 3b) ----------------------------------------------
  // Fused (not (pair? X))+jump: pop stack; jump to target iff popped value IS a pair.
  |->op_jump_if_pair:
  | fetchOperand rax
  | sub STACK, 8
  | mov rdx, [STACK]
  | test rdx, rdx
  | je ->dispatch       // immediate 0 → not a pair → fall through
  | test rdx, 3
  | jnz ->dispatch      // fixnum/constant tag bits → not a pair → fall through
  | mov rcx, [rdx]
  | movzx rcx, cl
  | cmp rcx, PAIR
  | jne ->dispatch      // heap but wrong type → not a pair → fall through
  | jumpToOperandTarget rax   // is a pair → take the jump

  // --- OP_JUMP_IF_NOT_EQ_IMM (exp 3d) ----------------------------------------
  // Fused eq?-literal+jump: operands {const-idx, target}. Pops stack; jump to
  // target iff popped value != constants[idx]. Replaces
  //   push-constant idx; eq?; jump-when-pop L
  // used by compile-if for (if (eq? X 'LIT) ...) when LIT is a safe-immediate
  // literal (symbols, fixnums, booleans, '()).
  |->op_jump_if_not_eq_imm:
  | fetchOperand rcx                  // rcx = const-idx
  | fetchOperand rax                  // rax = jump target
  | mov rdx, [VFN + (ptrdiff_t) offsetof(VMFunction, constants)]
  | mov rdx, [rdx + rcx*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | sub STACK, 8
  | mov rcx, [STACK]
  | cmp rcx, rdx
  | je ->dispatch                     // equal → fall through (no jump)
  | jumpToOperandTarget rax           // not equal → take branch

  // --- OP_JUMP_IF_EQ_IMM (exp 3d) --------------------------------------------
  // Fused (not (eq? X 'LIT))+jump: as above but jump iff equal.
  |->op_jump_if_eq_imm:
  | fetchOperand rcx
  | fetchOperand rax
  | mov rdx, [VFN + (ptrdiff_t) offsetof(VMFunction, constants)]
  | mov rdx, [rdx + rcx*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | sub STACK, 8
  | mov rcx, [STACK]
  | cmp rcx, rdx
  | jne ->dispatch                    // not equal → fall through
  | jumpToOperandTarget rax           // equal → take branch

  // --- OP_PUSH_CONSTANT (S3) -------------------------------------------------
  // PUSH_CONSTANT idx: push vfn->constants->data[idx]
  |->op_push_constant:
  | mov rcx, [VFN + (ptrdiff_t) offsetof(VMFunction, constants)]
  | fetchOperand rax
  | mov rdx, [rcx + rax*8 + (ptrdiff_t) offsetof(VectorStorage, data)]
  | pushReg rdx
  | jmp ->dispatch

  // --- OP_RETURN -------------------------------------------------------------
  // Pop the top VMCallFrame record. A SESSION_BASE record returns to C (the
  // session's vm_stack region is released here, mirroring apply_vm's
  // do_return); otherwise control resumes the caller frame in this loop.
  |->op_return:
  | mov rax, [STACK - 8]
  | mov edx, dword [VFN + (ptrdiff_t) offsetof(VMFunction, box_count)]
  | test rdx, rdx
  | jz >1
  | push rax
  | push rax
  | mov rdi, STATE
  | mov rsi, VFN
  | mov rdx, [rsp + 24]                // sff_offset (rsp moved by 2 pushes)
  | mov64 rax, (ptrdiff_t) &native_vm_close_frame_boxes
  | call rax
  | pop rax
  | pop rax
  | reloadDtable
  |1:
  | mov rdi, [STATE + NATIVE_VM_FRAMES_FINISH_OFF]
  | lea rdi, [rdi - FR_SIZE]           // rdi = top record (this frame)
  | test dword [rdi + 36], 1           // SESSION_BASE?
  | jz >2
  // Session return: release the session's stack region, pop the record,
  // hand the result back to apply_native_vm.
  | mov rcx, [rdi + 8]                 // frame_base
  | mov [STATE + NATIVE_VM_STACK_USED_OFF], rcx
  | mov [STATE + NATIVE_VM_FRAMES_FINISH_OFF], rdi
  | returnEpilogue
  |2:
  // Pop the record. vm_stack_used is a session high-water mark — it does NOT
  // shrink on non-base returns (frames overlap-allocate by stack discipline;
  // only session exit releases the region). Mirrors apply_vm's do_return.
  | mov [STATE + NATIVE_VM_FRAMES_FINISH_OFF], rdi  // pop record
  | dec qword [STATE + (ptrdiff_t) offsetof(State, vm_depth)]
  // Caller state from the new top record (rdi - FR_SIZE).
  | mov r11, [rdi - FR_SIZE]           // caller closure value
  | mov rdx, [r11]
  | movzx rdx, dl
  | cmp rdx, CLOSURE
  | jne >3
  | mov r11, [r11 + (ptrdiff_t) offsetof(Closure, function)]
  |3:
  | mov VFN, r11
  | mov rcx, [rsp]
  | mov [rcx], VFN                     // *vfn_ref = caller VMFunction
  | mov r11, [rdi - FR_SIZE + 8]       // caller frame_base
  | mov [rsp + 8], r11
  | mov rdx, [VFN + (ptrdiff_t) offsetof(VMFunction, code)]
  | lea rdx, [rdx + (ptrdiff_t) offsetof(Bytevector, data)]
  | mov [rsp + 24], rdx                // sCodeBase = caller code base
  | mov rcx, [rdi + 16]                // popped record's return_cp (words)
  | lea CP, [rdx + rcx*8]
  | mov r8, [STATE + NATIVE_VM_STACK_OFF]
  | lea LOCALS, [r8 + r11*8]
  | mov rdx, [rdi + 24]                // popped record's result_slot
  | mov [r8 + rdx*8], rax              // write result into caller's stack
  | lea STACK, [r8 + rdx*8 + 8]
  | lea rcx, [rdi - FR_SIZE]
  | mov [rsp + 16], rcx                // sClosureRef = caller record
  | reloadDtable
  | jmp ->dispatch

  // --- argc mismatch error ---------------------------------------------------
  |->argc_error:
  | mov rdi, STATE
  | mov rsi, ARGC
  | mov rdx, rax
  | mov64 rax, (ptrdiff_t) &native_vm_argc_error
  | call rax
  | jmp ->exception_return

  // --- argc less-than-minimum error (S3) -------------------------------------
  |->argc_gte_error:
  | mov rdi, STATE
  | mov rsi, ARGC
  | mov rdx, rax
  | mov64 rax, (ptrdiff_t) &native_vm_argc_gte_error
  | call rax
  | jmp ->exception_return

  // --- undefined-variable error paths (S5) ----------------------------------
  // Entered from OP_GLOBAL_GET — rdx holds the symbol.
  |->global_undefined:
  | mov rdi, STATE
  | mov rsi, rdx
  | xor edx, edx
  | mov64 rax, (ptrdiff_t) &native_vm_global_undefined
  | call rax
  | jmp ->exception_return

  // Entered from OP_GLOBAL_SET — rdx holds the symbol.
  |->set_undefined_error:
  | mov rdi, STATE
  | mov rsi, rdx
  | mov edx, 1
  | mov64 rax, (ptrdiff_t) &native_vm_global_undefined
  | call rax
  | jmp ->exception_return

  // --- CAR/CDR type-error trampolines (S6) ----------------------------------
  // The offending value is still on top of the stack; fetch from there.
  |->car_error:
  | mov rdi, STATE
  | mov rsi, [STACK - 8]
  | xor edx, edx
  | mov64 rax, (ptrdiff_t) &native_vm_pair_error
  | call rax
  | jmp ->exception_return

  |->cdr_error:
  | mov rdi, STATE
  | mov rsi, [STACK - 8]
  | mov edx, 1
  | mov64 rax, (ptrdiff_t) &native_vm_pair_error
  | call rax
  | jmp ->exception_return

  // --- OP_VALUE_HEADER_BIT error trampolines (are-8qgc) ---------------------
  |->value_header_bit_immediate:
  | mov rdi, STATE
  | mov64 rax, (ptrdiff_t) &native_vm_value_header_bit_immediate_error
  | call rax
  | jmp ->exception_return

  |->value_header_bit_nonfixnum:
  | mov rdi, STATE
  | mov64 rax, (ptrdiff_t) &native_vm_value_header_bit_nonfixnum_error
  | call rax
  | jmp ->exception_return

  // --- OP_APPLY error path (S7) ---------------------------------------------
  // The offending fn value is at [STACK - (fargc+1)*8]; but fargc is in rax
  // when we jump here. We stash the fn in r9 above; use it here. Terminal.
  |->apply_error:
  | mov rdi, STATE
  | mov rsi, r9
  | mov64 rax, (ptrdiff_t) &native_vm_apply_error
  | call rax
  | jmp ->exception_return

  // --- tail-return epilogue (S8) --------------------------------------------
  // Same epilogue as exception_return; separate label for clarity. Reached
  // with rax already holding the return value (C_FALSE on the tail path,
  // the callee's result on the non-tail path).
  |->tail_return_marker:
  | returnEpilogue

  // --- exception epilogue ----------------------------------------------------
  // Reached with the exception value already in rax, from every error
  // trampoline and every post-call active-exception check. Exports the
  // current frame's bytecode offset so the C-side unwind can trace the
  // innermost frame at the faulting instruction. CP and sCodeBase are always
  // updated together, so their difference is GC-safe even if the bytecode
  // Bytevector moved since the last rebase.
  |->exception_return:
  | mov rcx, CP
  | sub rcx, sCodeBase
  | shr rcx, 3
  | mov64 rdx, (ptrdiff_t) &native_vm_exc_cp_offset
  | mov [rdx], rcx
  | returnEpilogue

  // --- recursion-limit error (asm call fast path) ----------------------------
  |->recursion_limit_error:
  | mov rdi, STATE
  | mov64 rax, (ptrdiff_t) &native_vm_recursion_limit_error
  | call rax
  | jmp ->exception_return

  // --- unimplemented-opcode trampoline --------------------------------------
  |->bad_opcode:
  | mov rdi, STATE
  | mov64 rax, (ptrdiff_t) &native_vm_bad_opcode
  | call rax
  | jmp ->exception_return

  // --- non-sentinel frame-link return trap (Phase B stub) -------------------
  |->bad_frame_return:
  | .byte 0x0f, 0x0b
  | returnEpilogue

  size_t size;
  dasm_link(&d, &size);
  void* code_buf = state.allocate_native_code(size);
  dasm_encode(&d, code_buf);
  dasm_free(&d);

  native_vm_dispatch = (native_vm_dispatch_fn) globals[G_entry];

  for(size_t i = 0; i < sizeof(dispatch_table) / sizeof(void*); i++) {
    dispatch_table[i] = globals[G_bad_opcode];
  }
#define INSTALL_NATIVE_VM_DISPATCH(opcode, label) \
  dispatch_table[opcode] = globals[G_##label];
  NATIVE_VM_DISPATCH_OPS(INSTALL_NATIVE_VM_DISPATCH)
#undef INSTALL_NATIVE_VM_DISPATCH

  native_vm_mark_ready();
}

Value apply_native_vm(State& state, size_t argc, Value* argv, void* fnp) {
  AR_ASSERT(native_vm_dispatch != nullptr);

  PerfScope perf_scope(state, PERF_VM, &state.perf.vm_calls);

  // frames_lost carried across the tail_flag loop so a recycled session
  // frame's record keeps counting like apply_vm's link_frames_lost does.
  uint32_t session_frames_lost = 0;

tail:
  // closure and fn live in the current block scope. AR_FRAME registers
  // their *addresses* with the GC so a collection inside the dispatch loop
  // leaves the pointers updated in place. On `goto tail` these objects
  // are destructed and reconstructed — matching apply_vm's TCO pattern.
  {
  Value closure = Value((ptrdiff_t) fnp);
  Value fn = closure.closure_unbox();
  AR_FRAME(state, closure, fn);

  if(fn.type() == FUNCTION) {
    return apply_interpreter(state, argc, argv, (void*) fn.bits);
  }
  if(!fn.heap_type_equals(VMFUNCTION)) {
    return state.eval_error("native VM expected vm function", fn);
  }

  VMFunction* vfn = fn.as_unsafe<VMFunction>();
  if(vfn->code == nullptr) {
    return state.eval_error("native VM expected vm function with code", fn);
  }
  size_t frame_words = vfn->local_count + vfn->box_count + vfn->stack_max;

  size_t sff_offset = state.gc.vm_stack_used;
  state.vm_depth++;

  if(state.vm_depth >= state.recursion_limit) {
    state.vm_depth--;
    std::ostringstream os;
    os << " non-tail recursive calls exceeded RECURSION-LIMIT ("
       << state.recursion_limit << ')';
    return state.make_exception(State::S_EVAL_ERROR, os.str());
  }

  if(state.gc.stack_needs_realloc(frame_words) &&
     (size_t) argv >= (size_t) state.gc.vm_stack &&
     (size_t) argv <= ((size_t) state.gc.vm_stack +
                       (size_t)(state.gc.vm_stack_used * sizeof(void*)))) {
    size_t argv_offset = ((size_t) argv) - ((size_t) state.gc.vm_stack);
    state.gc.grow_stack(frame_words);
    argv = (Value*) (((size_t) state.gc.vm_stack) + argv_offset);
  } else {
    state.gc.grow_stack(frame_words);
  }

  vfn = fn.as_unsafe<VMFunction>();

  Value* locals = &state.gc.vm_stack[sff_offset];
  Value* stack  = locals + vfn->local_count + vfn->box_count;

  size_t locals_size = std::min(argc, (size_t) vfn->max_arity) * sizeof(Value);
  memcpy(locals, argv, locals_size);
  memset(((char*) locals) + locals_size, 0,
         (frame_words * sizeof(Value)) - locals_size);

  // Push this session's base frame record. The record roots `closure` for
  // the GC; the asm core derives the current frame base + closure pointer
  // from the top record, and pushes/pops the same records for nested calls.
  const size_t session_base_idx = state.gc.vm_frames.size();
  {
    VMCallFrame rec;
    rec.closure = closure;
    rec.frame_base = sff_offset;
    rec.return_cp = 0;
    rec.result_slot = 0;
    rec.frames_lost = session_frames_lost;
    rec.flags = (uint32_t) VMCallFrame::SESSION_BASE;
    state.gc.vm_frames.push_back(rec);
  }

  // Variable-arity prologue: ARGV_REST is a prologue-only opcode, so build
  // the rest list eagerly here and keep the dispatch handler as a no-op.
  //
  // max_arity is cached up front because temps_to_list allocates and can GC —
  // the raw vfn pointer becomes stale across the allocation, so we must not
  // re-read vfn->max_arity after.
  if(vfn->get_header_bit(Value::VMFUNCTION_VARIABLE_ARITY_BIT)) {
    size_t max_arity = vfn->max_arity;
    if(argc <= max_arity) {
      locals[max_arity] = C_NIL;
    } else if(!state.temps.empty() && argv == state.temps.data()) {
      Value rest = state.temps_to_list(max_arity);
      locals[max_arity] = rest;
    } else {
      state.temps.clear();
      state.temps.insert(state.temps.end(), &argv[max_arity], &argv[argc]);
      Value rest = state.temps_to_list();
      locals[max_arity] = rest;
    }
    vfn = fn.as_unsafe<VMFunction>();
  }

  // If this function will create closures over any of its locals, allocate
  // the Box objects that those closures will share. Mirrors apply_vm's
  // setup at src/vm.cpp:250.
  if(vfn->box_count) {
    Value* boxes = locals + vfn->local_count;
    state.gc.protect_argc = argc;
    state.gc.protect_argv = argv;
    size_t fv_length = fn.as_unsafe<VMFunction>()->free_variables->length;
    for(size_t i = 0; i != fv_length; i++) {
      boxes[i] = state.gc.allocate(BOX, sizeof(Box));
      vfn = fn.as_unsafe<VMFunction>();
      size_t local_idx = ((size_t*) vfn->free_variables->data)[i];
      size_t vm_stack_idx = sff_offset + local_idx;
      boxes[i].as<Box>()->U.vm_local_idx = vm_stack_idx;
    }
    state.gc.protect_argc = 0;
    vfn = fn.as_unsafe<VMFunction>();
  }

  native_vm_tail_flag = false;
  Value result = native_vm_dispatch(&state, &fn, locals, stack, argc,
                                    vfn->code_pointer());
  state.vm_depth--;

  // Three exits from the dispatch core:
  //  1. Normal return — OP_RETURN on the session-base record already popped
  //     it and released the session's vm_stack region; nothing left to do.
  //  2. Tail flag — the session-base record is still on vm_frames; recycle
  //     it (close boxes, release the region) and restart with the new fn.
  //  3. Exception — this session's records (one per still-live frame) are
  //     on vm_frames; unwind them innermost-first like apply_vm's exception
  //     loop, closing boxes per frame.
  if(state.gc.vm_frames.size() > session_base_idx) {
    if(native_vm_tail_flag) {
      AR_ASSERT(state.gc.vm_frames.size() == session_base_idx + 1);
      VMCallFrame top = state.gc.vm_frames.back();
      Value top_fn = top.closure.closure_unbox();
      native_vm_close_frame_boxes(&state, top_fn.as_unsafe<VMFunction>(),
                                  top.frame_base);
      state.gc.vm_frames.pop_back();
      state.gc.vm_stack_used = top.frame_base;
      session_frames_lost = top.frames_lost + 1;

      argc = native_vm_tail_argc;
      argv = native_vm_tail_use_buf
          ? native_vm_tail_buf
          : (state.temps.empty() ? nullptr : state.temps.data());
      fnp  = native_vm_tail_fnp;
      goto tail;
    }

    // Unwind innermost-first, emitting one stack-trace entry per frame like
    // apply_vm's exception loop: the innermost frame traces at the faulting
    // instruction (exported by the asm exception epilogue), parents at their
    // call sites.
    size_t trace_off = native_vm_exc_cp_offset;
    while(state.gc.vm_frames.size() > session_base_idx) {
      VMCallFrame fr = state.gc.vm_frames.back();
      Value frame_fn = fr.closure.closure_unbox();
      if(result.exception_trace()) {
        state.trace_function(frame_fn, fr.frames_lost, trace_off);
      }
      native_vm_close_frame_boxes(&state, frame_fn.as_unsafe<VMFunction>(),
                                  fr.frame_base);
      state.gc.vm_frames.pop_back();
      if(fr.flags & VMCallFrame::SESSION_BASE) {
        // The session's own vm_depth increment was already undone above.
        state.gc.vm_stack_used = fr.frame_base;
      } else {
        // Undo the asm fast path's per-frame vm_depth increment.
        state.vm_depth--;
      }
      trace_off = fr.return_cp;
    }
  }
  return result;
  }
}

} // namespace arete

#else

namespace arete {
// Stub versions of apply_native_vm / init_native_vm live in vm-native.cpp
// on platforms without an assembled dispatch core.
}

#endif
